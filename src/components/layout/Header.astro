---
// src/components/layout/Header.astro
// 功能：网站头部导航 — Logo、导航链接、分类/话题下拉菜单、搜索、语言切换、主题切换、用户认证状态、移动端菜单
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
  getAlternateLanguagePath,
} from '@/i18n/utils';
import { siteConfig } from '@/config/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

function getLabel(item: { zh?: string; en?: string; labelKey?: string }): string {
  if (item.labelKey) return t(item.labelKey as any);
  return lang === 'en' ? item.en || item.zh || '' : item.zh || item.en || '';
}

const otherLang = lang === 'zh' ? 'en' : 'zh';
const otherLangPath = getAlternateLanguagePath(currentPath, otherLang);

const user = Astro.locals.user;

const categoryIcons: Record<string, string> = {
  'building-2':
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 22V4a2 2 0 012-2h8a2 2 0 012 2v18M6 12H4a2 2 0 00-2 2v6a2 2 0 002 2h2m10-12h2a2 2 0 012 2v6a2 2 0 01-2 2h-2m-6 0h6M6 8h8M6 16h8" />',
  'book-open':
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2zM22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" />',
  rocket:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09zM12 15l-3-3M22 2l-7 7m0 0l-3-3m3 3l3-3" />',
  'bar-chart-3':
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 20V10M12 20V4M6 20v-6" />',
  'code-2':
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 7l-5 5 5 5M7 7l5 5-5 5" />',
  scale:
    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707" />',
};
---

<header
  class="header-sticky sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-xl"
>
  <div class="mx-auto flex h-12 max-w-7xl items-center justify-between px-4">
    {/* Logo */}
    <a
      href={getLocalizedPath('/', lang)}
      class="flex items-center gap-2 text-xl font-bold tracking-tight"
    >
      <span class="text-accent">Fael</span><span class="text-text-primary">AI</span>
    </a>

    {/* Desktop Nav */}
    <nav class="hidden items-center gap-1 md:flex">
      {
        siteConfig.nav.map((link) => {
          const isActive = currentPath === getLocalizedPath(link.path, lang);
          return (
            <a
              href={getLocalizedPath(link.path, lang)}
              class:list={[
                'nav-link relative px-3 py-1.5 text-sm transition-colors duration-150',
                isActive
                  ? 'font-medium text-text-primary'
                  : 'text-text-secondary hover:text-text-primary',
              ]}
            >
              {t(link.labelKey as any)}
            </a>
          );
        })
      }

      {/* Categories Dropdown */}
      <div class="relative header-dropdown">
        <button
          class="flex items-center gap-1 px-3 py-1.5 text-sm text-text-secondary transition-colors duration-150 hover:text-text-primary"
        >
          {t('nav.categories')}
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
            ></path>
          </svg>
        </button>
        <div
          class="dropdown-menu invisible absolute left-1/2 top-full z-50 mt-2 w-56 -translate-x-1/2 rounded-xl border border-border bg-background p-1.5 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100"
          style="box-shadow: 0 1px 1px rgba(0,0,0,0.02), 0 4px 8px -4px rgba(0,0,0,0.04), 0 16px 24px -8px rgba(0,0,0,0.06);"
        >
          {
            siteConfig.categories.map((cat) => (
              <a
                href={getLocalizedPath(cat.path, lang)}
                class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary"
              >
                <svg
                  class="h-4 w-4 shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  set:html={categoryIcons[cat.icon] || ''}
                />
                <span>{getLabel(cat)}</span>
              </a>
            ))
          }
        </div>
      </div>

      {/* Topics Dropdown */}
      <div class="relative header-dropdown">
        <button
          class="flex items-center gap-1 px-3 py-1.5 text-sm text-text-secondary transition-colors duration-150 hover:text-text-primary"
        >
          {t('nav.topics')}
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
            ></path>
          </svg>
        </button>
        <div
          class="dropdown-menu invisible absolute left-1/2 top-full z-50 mt-2 w-48 -translate-x-1/2 rounded-xl border border-border bg-background p-1.5 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100"
          style="box-shadow: 0 1px 1px rgba(0,0,0,0.02), 0 4px 8px -4px rgba(0,0,0,0.04), 0 16px 24px -8px rgba(0,0,0,0.06);"
        >
          {
            siteConfig.topics.map((topic) => (
              <a
                href={getLocalizedPath(topic.path, lang)}
                class="block rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary"
              >
                {getLabel(topic)}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    {/* Right Actions */}
    <div class="flex items-center gap-1">
      {/* Search */}
      <a
        href={getLocalizedPath('/search', lang)}
        class="icon-btn flex h-9 w-9 items-center justify-center rounded-md text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary"
        aria-label={t('nav.search')}
      >
        <svg class="h-[18px] w-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </a>

      {/* Lang Toggle */}
      <a
        href={otherLangPath}
        class="flex h-9 items-center rounded-md px-3 text-sm font-medium text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary"
      >
        {otherLang === 'zh' ? '中' : 'EN'}
      </a>

      {/* Theme Toggle */}
      <button
        data-theme-toggle
        class="icon-btn flex h-9 w-9 items-center justify-center rounded-md text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary"
        aria-label="Toggle theme"
      >
        <svg class="h-[18px] w-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
      </button>

      {/* Auth */}
      {
        user ? (
          <a
            href={getLocalizedPath('/dashboard', lang)}
            class="btn-primary flex h-9 items-center gap-2 rounded-md bg-text-primary px-4 text-sm font-medium text-background transition-colors duration-150 hover:opacity-90"
          >
            {user.avatarUrl ? (
              <img
                src={user.avatarUrl}
                alt={user.username}
                class="h-6 w-6 rounded-full object-cover"
              />
            ) : (
              <div class="flex h-6 w-6 items-center justify-center rounded-full bg-border text-xs font-medium text-text-primary">
                {(user.fullName || user.username)[0].toUpperCase()}
              </div>
            )}
            <span class="hidden sm:inline">{user.username}</span>
          </a>
        ) : (
          <div class="hidden items-center gap-1.5 md:flex">
            <a
              href={getLocalizedPath('/login', lang)}
              class="btn-secondary rounded-md px-4 py-2 text-sm font-medium text-text-primary transition-colors duration-150 hover:bg-card-hover"
            >
              {t('nav.login')}
            </a>
            <a
              href={getLocalizedPath('/register', lang)}
              class="btn-primary rounded-md bg-text-primary px-4 py-2 text-sm font-medium text-background transition-colors duration-150 hover:opacity-90"
            >
              {t('nav.register')}
            </a>
          </div>
        )
      }

      {/* Mobile Menu */}
      <button
        id="mobile-menu-toggle"
        class="icon-btn flex h-9 w-9 items-center justify-center rounded-md text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary md:hidden"
        aria-label="Menu"
      >
        <svg class="h-[18px] w-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile Menu Panel */}
  <div id="mobile-menu" class="hidden border-t border-border bg-background md:hidden">
    <nav class="flex flex-col p-3">
      {
        siteConfig.nav.map((link) => (
          <a
            href={getLocalizedPath(link.path, lang)}
            class="rounded-lg px-4 py-2.5 text-sm text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary"
          >
            {t(link.labelKey as any)}
          </a>
        ))
      }
      <div class="my-2 border-t border-border"></div>
      <p class="px-4 py-1.5 text-xs font-medium uppercase tracking-wider text-text-disabled">
        {t('nav.categories')}
      </p>
      {
        siteConfig.categories.map((cat) => (
          <a
            href={getLocalizedPath(cat.path, lang)}
            class="flex items-center gap-3 rounded-lg px-4 py-2.5 text-sm text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary"
          >
            <svg
              class="h-4 w-4 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              set:html={categoryIcons[cat.icon] || ''}
            />
            <span>{getLabel(cat)}</span>
          </a>
        ))
      }
      <div class="my-2 border-t border-border"></div>
      {
        user ? (
          <a
            href={getLocalizedPath('/dashboard', lang)}
            class="rounded-lg px-4 py-2.5 text-sm font-medium text-text-primary transition-colors duration-150 hover:bg-card-hover"
          >
            {t('nav.dashboard')}
          </a>
        ) : (
          <>
            <a
              href={getLocalizedPath('/login', lang)}
              class="rounded-lg px-4 py-2.5 text-sm text-text-secondary transition-colors duration-150 hover:bg-card-hover hover:text-text-primary"
            >
              {t('nav.login')}
            </a>
            <a
              href={getLocalizedPath('/register', lang)}
              class="mt-2 rounded-lg bg-text-primary px-4 py-2.5 text-center text-sm font-medium text-background transition-colors duration-150 hover:opacity-90"
            >
              {t('nav.register')}
            </a>
          </>
        )
      }
    </nav>
  </div>
</header>

<style>
  .header-dropdown:hover .dropdown-menu {
    visibility: visible;
    opacity: 1;
  }

  .icon-btn:focus-visible,
  .nav-link:focus-visible,
  .btn-primary:focus-visible,
  .btn-secondary:focus-visible {
    box-shadow:
      0 0 0 2px var(--color-background, #fff),
      0 0 0 4px #006bff;
    outline: none;
  }

  .btn-primary {
    height: 40px;
  }

  .btn-secondary {
    height: 40px;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  });
</script>
