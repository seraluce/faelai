---
// src/layouts/AdminLayout.astro
// 功能：管理后台布局 — Geist 设计系统风格，左侧导航栏、移动端适配、简版页脚
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
---

<div class="flex min-h-screen bg-background">
  {/* Admin Sidebar — Desktop */}
  <aside
    class="fixed inset-y-0 left-0 z-40 hidden w-60 border-r border-border bg-background md:block"
  >
    <div class="flex h-12 items-center border-b border-border px-4">
      <a
        href={getLocalizedPath('/', lang)}
        class="flex items-center gap-2 text-sm font-semibold tracking-tight"
      >
        <span class="text-accent">Fael</span><span class="text-text-primary">AI</span>
      </a>
    </div>
    <nav class="flex flex-col gap-0.5 p-2">
      <a
        href="/admin"
        class:list={[
          'flex h-9 items-center gap-2.5 rounded-[6px] px-2.5 text-[13px] transition-all duration-150',
          currentPath === '/admin'
            ? 'bg-background-hover text-text-primary font-medium'
            : 'text-text-secondary hover:bg-background-hover hover:text-text-primary',
        ]}
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
          ></path></svg
        >
        {t('admin.stats')}
      </a>
      <a
        href="/admin/articles"
        class:list={[
          'flex h-9 items-center gap-2.5 rounded-[6px] px-2.5 text-[13px] transition-all duration-150',
          currentPath.startsWith('/admin/articles')
            ? 'bg-background-hover text-text-primary font-medium'
            : 'text-text-secondary hover:bg-background-hover hover:text-text-primary',
        ]}
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path></svg
        >
        {t('admin.articles')}
      </a>
      <a
        href="/admin/feeds"
        class:list={[
          'flex h-9 items-center gap-2.5 rounded-[6px] px-2.5 text-[13px] transition-all duration-150',
          currentPath.startsWith('/admin/feeds')
            ? 'bg-background-hover text-text-primary font-medium'
            : 'text-text-secondary hover:bg-background-hover hover:text-text-primary',
        ]}
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"
          ></path></svg
        >
        {t('admin.feeds')}
      </a>
      <a
        href="/admin/categories"
        class:list={[
          'flex h-9 items-center gap-2.5 rounded-[6px] px-2.5 text-[13px] transition-all duration-150',
          currentPath.startsWith('/admin/categories')
            ? 'bg-background-hover text-text-primary font-medium'
            : 'text-text-secondary hover:bg-background-hover hover:text-text-primary',
        ]}
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"
          ></path></svg
        >
        {t('admin.categories')}
      </a>
      <a
        href="/admin/tags"
        class:list={[
          'flex h-9 items-center gap-2.5 rounded-[6px] px-2.5 text-[13px] transition-all duration-150',
          currentPath.startsWith('/admin/tags')
            ? 'bg-background-hover text-text-primary font-medium'
            : 'text-text-secondary hover:bg-background-hover hover:text-text-primary',
        ]}
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"
          ></path></svg
        >
        {t('admin.tags')}
      </a>
      <a
        href="/admin/users"
        class:list={[
          'flex h-9 items-center gap-2.5 rounded-[6px] px-2.5 text-[13px] transition-all duration-150',
          currentPath.startsWith('/admin/users')
            ? 'bg-background-hover text-text-primary font-medium'
            : 'text-text-secondary hover:bg-background-hover hover:text-text-primary',
        ]}
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"
          ></path></svg
        >
        {t('admin.users')}
      </a>
      <a
        href="/admin/settings"
        class:list={[
          'flex h-9 items-center gap-2.5 rounded-[6px] px-2.5 text-[13px] transition-all duration-150',
          currentPath.startsWith('/admin/settings')
            ? 'bg-background-hover text-text-primary font-medium'
            : 'text-text-secondary hover:bg-background-hover hover:text-text-primary',
        ]}
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
          ></path><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
        >
        {t('admin.settings')}
      </a>

      <div class="my-1.5 border-t border-border"></div>

      <a
        href={getLocalizedPath('/', lang)}
        class="flex h-9 items-center gap-2.5 rounded-[6px] px-2.5 text-[13px] text-text-secondary transition-all duration-150 hover:bg-background-hover hover:text-text-primary"
      >
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
        >
        {lang === 'zh' ? '返回前台' : 'Back to Site'}
      </a>
    </nav>
  </aside>

  {/* Mobile Admin Header */}
  <div
    class="fixed inset-x-0 top-0 z-50 flex h-12 items-center justify-between border-b border-border bg-background px-4 md:hidden"
  >
    <a
      href={getLocalizedPath('/', lang)}
      class="flex items-center gap-2 text-sm font-semibold tracking-tight"
    >
      <span class="text-accent">Fael</span><span class="text-text-primary">AI</span>
    </a>
    <div class="flex items-center gap-1">
      <a
        href="/admin"
        class="flex h-8 w-8 items-center justify-center rounded-[6px] text-text-secondary transition-colors duration-150 hover:bg-background-hover hover:text-text-primary"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
          ></path></svg
        >
      </a>
      <a
        href={getLocalizedPath('/', lang)}
        class="flex h-8 items-center gap-1.5 rounded-[6px] px-2.5 text-[13px] text-text-secondary transition-colors duration-150 hover:bg-background-hover hover:text-text-primary"
      >
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
        >
        {lang === 'zh' ? '前台' : 'Site'}
      </a>
    </div>
  </div>

  {/* Main Content Area */}
  <div class="flex-1 md:ml-60">
    <div class="flex min-h-screen flex-col pt-12 md:pt-0">
      <div class="flex-1">
        <slot />
      </div>
      <footer class="border-t border-border px-4 py-3 text-center text-[12px] text-text-disabled">
        FaelAI Admin &copy; {new Date().getFullYear()}
      </footer>
    </div>
  </div>
</div>
