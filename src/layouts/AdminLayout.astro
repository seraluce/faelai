---
// src/layouts/AdminLayout.astro
// 功能：管理后台布局 — 左侧导航栏（文章/分类/标签/RSS/用户/设置）、返回前台按钮、移动端适配
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const user = Astro.locals.user;
---

<!-- Admin Layout: no header/footer, just admin sidebar + content -->
<div class="flex min-h-screen bg-background">
  {/* Admin Sidebar */}
  <aside class="fixed inset-y-0 left-0 z-40 hidden w-60 border-r border-border bg-background-secondary md:block">
    <div class="flex h-14 items-center border-b border-border px-4">
      <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 text-lg font-bold">
        <span class="text-accent">Fael</span><span class="text-text-primary">AI</span>
      </a>
    </div>
    <nav class="flex flex-col gap-1 p-3">
      <a
        href="/admin"
        class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${
          currentPath === '/admin' ? 'bg-accent/10 font-medium text-accent' : 'text-text-secondary hover:bg-background-hover hover:text-text-primary'
        }`}
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
        {t('admin.stats')}
      </a>
      <a
        href="/admin/articles"
        class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${
          currentPath.startsWith('/admin/articles') ? 'bg-accent/10 font-medium text-accent' : 'text-text-secondary hover:bg-background-hover hover:text-text-primary'
        }`}
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
        {t('admin.articles')}
      </a>
      <a
        href="/admin/feeds"
        class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${
          currentPath.startsWith('/admin/feeds') ? 'bg-accent/10 font-medium text-accent' : 'text-text-secondary hover:bg-background-hover hover:text-text-primary'
        }`}
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
        {t('admin.feeds')}
      </a>
      <a
        href="/admin/categories"
        class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${
          currentPath.startsWith('/admin/categories') ? 'bg-accent/10 font-medium text-accent' : 'text-text-secondary hover:bg-background-hover hover:text-text-primary'
        }`}
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" /></svg>
        {t('admin.categories')}
      </a>
      <a
        href="/admin/tags"
        class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${
          currentPath.startsWith('/admin/tags') ? 'bg-accent/10 font-medium text-accent' : 'text-text-secondary hover:bg-background-hover hover:text-text-primary'
        }`}
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" /></svg>
        {t('admin.tags')}
      </a>
      <a
        href="/admin/users"
        class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${
          currentPath.startsWith('/admin/users') ? 'bg-accent/10 font-medium text-accent' : 'text-text-secondary hover:bg-background-hover hover:text-text-primary'
        }`}
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" /></svg>
        {t('admin.users')}
      </a>
      <a
        href="/admin/settings"
        class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${
          currentPath.startsWith('/admin/settings') ? 'bg-accent/10 font-medium text-accent' : 'text-text-secondary hover:bg-background-hover hover:text-text-primary'
        }`}
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        {t('admin.settings')}
      </a>

      <div class="my-2 border-t border-border" />

      {/* 返回前台 */}
      <a
        href={getLocalizedPath('/', lang)}
        class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        {lang === 'zh' ? '返回前台' : 'Back to Site'}
      </a>
    </nav>
  </aside>

  {/* Mobile Admin Header */}
  <div class="fixed inset-x-0 top-0 z-50 flex h-14 items-center justify-between border-b border-border bg-background px-4 md:hidden">
    <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 text-lg font-bold">
      <span class="text-accent">Fael</span><span class="text-text-primary">AI</span>
    </a>
    <div class="flex items-center gap-2">
      <a href="/admin" class="flex h-8 w-8 items-center justify-center rounded-lg text-text-secondary hover:bg-background-hover">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
      </a>
      <a href={getLocalizedPath('/', lang)} class="flex h-8 items-center gap-1 rounded-lg px-3 text-xs text-text-secondary hover:bg-background-hover">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        {lang === 'zh' ? '前台' : 'Site'}
      </a>
    </div>
  </div>

  {/* Main Content Area */}
  <div class="flex-1 md:ml-60">
    <div class="pt-14 md:pt-0">
      <slot />
    </div>
  </div>
</div>
