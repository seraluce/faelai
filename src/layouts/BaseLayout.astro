---
// src/layouts/BaseLayout.astro
// 功能：基础 HTML 布局 — head 标签（SEO/OG 自动生成/JSON-LD）、Header/Footer 插槽、主题切换、字体加载
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { siteConfig } from '@/config/site';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogColor?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishedAt?: string;
  updatedAt?: string;
}

const {
  title,
  description = siteConfig.description,
  image,
  ogColor,
  canonical,
  type = 'website',
  publishedAt,
  updatedAt,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const siteTitle = `${title} | ${siteConfig.name}`;
const siteUrl = siteConfig.url;
const currentUrl = `${siteUrl}${Astro.url.pathname}`;
const canonicalUrl = canonical || currentUrl;

// OG 图片：优先使用传入的 image，否则自动生成 SVG
const ogParams = new URLSearchParams({
  title,
  subtitle: description,
  lang,
  ...(ogColor ? { color: ogColor } : {}),
});
const autoOgImage = `${siteUrl}/api/og.svg?${ogParams.toString()}`;
const ogImage = image || autoOgImage;
---

<!doctype html>
<html {lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <meta name="robots" content="index, follow" />
    <meta name={siteConfig.name.toLowerCase()} content={siteConfig.name} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph — 自动生成 */}
    <meta property="og:type" content={type} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />

    {/* Twitter Card — 自动生成 */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@faelai" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Article meta */}
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {updatedAt && <meta property="article:modified_time" content={updatedAt} />}
    {type === 'article' && <meta property="article:author" content={siteConfig.name} />}

    {/* Favicon — SVG 优先 */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" href="/apple-touch-icon.svg" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{siteTitle}</title>

    {/* RSS autodiscovery */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteConfig.name} RSS`}
      href="/rss.xml"
    />

    {/* Preconnect */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {/* JSON-LD Structured Data */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': type === 'article' ? 'Article' : 'WebSite',
        name: siteTitle,
        url: currentUrl,
        description,
        image: ogImage,
        publisher: {
          '@type': 'Organization',
          name: siteConfig.name,
          url: siteUrl,
        },
        ...(type === 'article' && publishedAt
          ? {
              datePublished: publishedAt,
              dateModified: updatedAt || publishedAt,
            }
          : {}),
      })}
    />

    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.classList.toggle('dark', theme === 'dark');
      document.documentElement.classList.toggle('light', theme === 'light');
    </script>
  </head>
  <body class="min-h-screen bg-background text-text-primary antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const toggleBtns = document.querySelectorAll('[data-theme-toggle]');
        toggleBtns.forEach((btn) => {
          btn.addEventListener('click', () => {
            const isDark = document.documentElement.classList.contains('dark');
            const newTheme = isDark ? 'light' : 'dark';
            document.documentElement.classList.toggle('dark', newTheme === 'dark');
            document.documentElement.classList.toggle('light', newTheme === 'light');
            localStorage.setItem('theme', newTheme);

            const iframe = document.querySelector('iframe.giscus-frame');
            if (iframe) {
              iframe.contentWindow.postMessage(
                { giscus: { setConfig: { theme: newTheme } } },
                'https://giscus.app'
              );
            }
          });
        });
      });
    </script>
  </body>
</html>
