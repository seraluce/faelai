---
// src/pages/404.astro
// 功能：404 页面（中文） — 页面未找到提示、返回首页/返回上一页按钮
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title="404" description="页面未找到">
  <div class="mx-auto flex min-h-[calc(100vh-16rem)] max-w-lg flex-col items-center justify-center px-4 text-center">
    <div class="mb-8">
      <svg class="mx-auto h-24 w-24 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    <h1 class="mb-4 text-6xl font-bold text-text-primary">404</h1>
    <p class="mb-2 text-lg text-text-secondary">
      {lang === 'zh' ? '页面未找到' : 'Page Not Found'}
    </p>
    <p class="mb-8 text-sm text-text-tertiary">
      {lang === 'zh' ? '你访问的页面不存在或已被移除' : 'The page you are looking for does not exist or has been removed'}
    </p>
    <div class="flex gap-3">
      <a
        href={getLocalizedPath('/', lang)}
        class="rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        {t('nav.home')}
      </a>
      <button
        onclick="history.back()"
        class="rounded-lg border border-border bg-background px-6 py-2.5 text-sm font-medium text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
      >
        {t('common.back')}
      </button>
    </div>
  </div>
</BaseLayout>
