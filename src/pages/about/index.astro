---
// src/pages/about/index.astro
// 功能：关于页面（中文） — 使命、特性介绍、技术栈、联系方式
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('nav.about')}>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <div class="mb-12 text-center">
      <h1 class="text-3xl font-bold text-text-primary md:text-4xl">关于 FaelAI</h1>
      <p class="mt-4 text-lg text-text-secondary">
        智能驱动的 AI 新闻聚合平台
      </p>
    </div>

    <div class="space-y-12">
      {/* Mission */}
      <section class="rounded-xl border border-border bg-card p-8">
        <h2 class="mb-4 text-xl font-semibold text-text-primary">我们的使命</h2>
        <p class="text-text-secondary leading-relaxed">
          FaelAI 致力于为 AI 从业者和爱好者提供最及时、最全面的人工智能领域资讯。我们通过 RSS 聚合全球优质 AI 新闻源，结合智能排序和分类，帮助你快速了解行业动态。
        </p>
      </section>

      {/* Features */}
      <section>
        <h2 class="mb-6 text-xl font-semibold text-text-primary">核心功能</h2>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-xl border border-border bg-card p-6">
            <div class="mb-3 text-2xl">📰</div>
            <h3 class="mb-2 font-semibold text-text-primary">RSS 聚合</h3>
            <p class="text-sm text-text-secondary">自动抓取全球主流 AI 新闻源，实时更新</p>
          </div>
          <div class="rounded-xl border border-border bg-card p-6">
            <div class="mb-3 text-2xl">🔥</div>
            <h3 class="mb-2 font-semibold text-text-primary">热门排行</h3>
            <p class="text-sm text-text-secondary">基于阅读量和互动数据的智能排序</p>
          </div>
          <div class="rounded-xl border border-border bg-card p-6">
            <div class="mb-3 text-2xl">🏷️</div>
            <h3 class="mb-2 font-semibold text-text-primary">分类标签</h3>
            <p class="text-sm text-text-secondary">精细的分类体系，快速定位感兴趣的内容</p>
          </div>
          <div class="rounded-xl border border-border bg-card p-6">
            <div class="mb-3 text-2xl">🌍</div>
            <h3 class="mb-2 font-semibold text-text-primary">多语言支持</h3>
            <p class="text-sm text-text-secondary">中英文双语界面，服务全球用户</p>
          </div>
        </div>
      </section>

      {/* Tech Stack */}
      <section class="rounded-xl border border-border bg-card p-8">
        <h2 class="mb-4 text-xl font-semibold text-text-primary">技术栈</h2>
        <div class="flex flex-wrap gap-2">
          {['Astro', 'React', 'Tailwind CSS', 'Turso', 'Drizzle ORM', 'Cloudflare R2', 'TypeScript'].map(tech => (
            <span class="rounded-full border border-border px-4 py-2 text-sm text-text-secondary">
              {tech}
            </span>
          ))}
        </div>
      </section>

      {/* Contact */}
      <section class="rounded-xl border border-border bg-card p-8 text-center">
        <h2 class="mb-4 text-xl font-semibold text-text-primary">联系我们</h2>
        <p class="mb-4 text-text-secondary">有任何问题或建议？欢迎联系我们</p>
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          GitHub
        </a>
      </section>
    </div>
  </div>
</BaseLayout>
