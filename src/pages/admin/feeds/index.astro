---
// src/pages/admin/feeds/index.astro
// 功能：RSS 源管理页面 — 源列表、新增/编辑/删除、启用/禁用
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/login');
}
---

<AdminLayout>
  <div class="px-4 py-8 md:px-8">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">{t('admin.feeds')}</h1>
        <p class="mt-1 text-text-secondary">管理 RSS 新闻源</p>
      </div>
      <button
        id="btn-add"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"
          ></path></svg
        >
        添加 RSS 源
      </button>
    </div>

    <div class="rounded-xl border border-border bg-card">
      <div id="feed-list" class="divide-y divide-border">
        <div class="p-8 text-center text-text-tertiary">加载中...</div>
      </div>
    </div>

    {/* 编辑弹窗 */}
    <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
      <div class="w-full max-w-lg rounded-xl border border-border bg-background p-6">
        <h2 id="modal-title" class="mb-4 text-lg font-bold text-text-primary">添加 RSS 源</h2>
        <form id="feed-form" class="space-y-4">
          <input type="hidden" id="edit-id" />
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="edit-name" class="mb-1 block text-xs text-text-secondary">名称</label>
              <input
                type="text"
                id="edit-name"
                required
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              />
            </div>
            <div>
              <label for="edit-lang" class="mb-1 block text-xs text-text-secondary">语言</label>
              <select
                id="edit-lang"
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              >
                <option value="en">英文</option>
                <option value="zh">中文</option>
              </select>
            </div>
          </div>
          <div>
            <label for="edit-url" class="mb-1 block text-xs text-text-secondary">RSS URL</label>
            <input
              type="url"
              id="edit-url"
              required
              placeholder="https://example.com/feed.xml"
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary placeholder-text-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>
          <div>
            <label for="edit-siteUrl" class="mb-1 block text-xs text-text-secondary">网站 URL</label
            >
            <input
              type="url"
              id="edit-siteUrl"
              placeholder="https://example.com"
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary placeholder-text-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>
          <div>
            <label for="edit-description" class="mb-1 block text-xs text-text-secondary">描述</label
            >
            <textarea
              id="edit-description"
              rows="2"
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            ></textarea>
          </div>
          <div>
            <label for="edit-fetchInterval" class="mb-1 block text-xs text-text-secondary"
              >抓取间隔（秒）</label
            >
            <input
              type="number"
              id="edit-fetchInterval"
              value="3600"
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>
          <div class="flex justify-end gap-2 pt-2">
            <button
              type="button"
              id="btn-cancel"
              class="rounded-lg border border-border px-4 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover"
              >取消</button
            >
            <button
              type="submit"
              class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
              >保存</button
            >
          </div>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const modal = document.getElementById('modal');
  const form = document.getElementById('feed-form');
  let editingId: string | null = null;

  function openModal(feed?: any) {
    editingId = feed?.id || null;
    document.getElementById('modal-title').textContent = feed ? '编辑 RSS 源' : '添加 RSS 源';
    document.getElementById('edit-id').value = feed?.id || '';
    document.getElementById('edit-name').value = feed?.name || '';
    document.getElementById('edit-url').value = feed?.url || '';
    document.getElementById('edit-siteUrl').value = feed?.siteUrl || '';
    document.getElementById('edit-description').value = feed?.description || '';
    document.getElementById('edit-lang').value = feed?.lang || 'en';
    document.getElementById('edit-fetchInterval').value = feed?.fetchInterval || 3600;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  async function loadFeeds() {
    try {
      const res = await fetch('/api/feeds');
      const data = await res.json();
      const list = document.getElementById('feed-list');

      if (!data.feeds || data.feeds.length === 0) {
        list.innerHTML = `<div class="p-8 text-center text-text-tertiary">暂无 RSS 源</div>`;
        return;
      }

      list.innerHTML = data.feeds
        .map(
          (f) => `
        <div class="flex items-center justify-between px-4 py-3 hover:bg-background-hover">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-text-primary">${f.name}</span>
              <span class="rounded bg-background-hover px-1.5 py-0.5 text-xs text-text-tertiary">${f.lang || 'en'}</span>
              ${f.isActive ? '<span class="rounded-full bg-success/10 px-2 py-0.5 text-xs text-success">启用</span>' : '<span class="rounded-full bg-text-tertiary/10 px-2 py-0.5 text-xs text-text-tertiary">禁用</span>'}
            </div>
            <p class="mt-1 truncate text-xs text-text-tertiary">${f.url}</p>
          </div>
          <div class="flex items-center gap-2">
            <button data-toggle='${JSON.stringify({ id: f.id, isActive: !f.isActive })}' class="toggle-btn rounded p-1 text-text-tertiary transition-colors hover:bg-background-hover hover:text-text-primary" title="${f.isActive ? '禁用' : '启用'}">
              ${
                f.isActive
                  ? '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>'
                  : '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
              }
            </button>
            <button data-edit='${JSON.stringify(f)}' class="edit-btn rounded p-1 text-text-tertiary transition-colors hover:bg-background-hover hover:text-text-primary">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            </button>
            <button data-delete="${f.id}" class="delete-btn rounded p-1 text-text-tertiary transition-colors hover:bg-background-hover hover:text-error">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            </button>
          </div>
        </div>
      `
        )
        .join('');

      list.querySelectorAll('.toggle-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const data = JSON.parse(btn.dataset.toggle);
          await fetch('/api/feeds', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          loadFeeds();
        });
      });

      list.querySelectorAll('.edit-btn').forEach((btn) => {
        btn.addEventListener('click', () => openModal(JSON.parse(btn.dataset.edit)));
      });

      list.querySelectorAll('.delete-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          if (!confirm('确定删除此 RSS 源？')) return;
          await fetch('/api/feeds', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: btn.dataset.delete }),
          });
          loadFeeds();
        });
      });
    } catch {
      document.getElementById('feed-list').innerHTML =
        `<div class="p-8 text-center text-error">加载失败</div>`;
    }
  }

  document.getElementById('btn-add')?.addEventListener('click', () => openModal());
  document.getElementById('btn-cancel')?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const body = {
      id: editingId || undefined,
      name: document.getElementById('edit-name').value,
      url: document.getElementById('edit-url').value,
      siteUrl: document.getElementById('edit-siteUrl').value || undefined,
      description: document.getElementById('edit-description').value || undefined,
      lang: document.getElementById('edit-lang').value,
      fetchInterval: parseInt(document.getElementById('edit-fetchInterval').value) || 3600,
    };
    const method = editingId ? 'PUT' : 'POST';
    const res = await fetch('/api/feeds', {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();
    if (data.success) {
      closeModal();
      loadFeeds();
    } else alert(data.error || '操作失败');
  });

  loadFeeds();
</script>
