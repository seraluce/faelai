---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/${lang}/login`);
}

const stats = [
  { label: '总文章数', value: '128', change: '+12', icon: 'document' },
  { label: '总用户数', value: '2,456', change: '+89', icon: 'users' },
  { label: '今日访问', value: '12,340', change: '+5.2%', icon: 'chart-bar' },
  { label: 'RSS 源', value: '24', change: '+2', icon: 'rss' },
];

const recentArticles = [
  { title: 'OpenAI 发布 GPT-5', status: 'published', views: 3200, date: '2 小时前' },
  { title: 'Anthropic Claude 4 安全报告', status: 'published', views: 2100, date: '4 小时前' },
  { title: 'DeepMind 蛋白质折叠突破', status: 'published', views: 1800, date: '6 小时前' },
  { title: 'Meta Llama 4 开源模型', status: 'draft', views: 0, date: '8 小时前' },
  { title: 'AI 监管新政策', status: 'review', views: 0, date: '12 小时前' },
];

const statusColors: Record<string, string> = {
  published: 'bg-success/10 text-success',
  draft: 'bg-warning/10 text-warning',
  review: 'bg-accent/10 text-accent',
};

const statusLabels: Record<string, string> = {
  published: '已发布',
  draft: '草稿',
  review: '审核中',
};
---

<AdminLayout>
  <div class="px-4 py-8 md:px-8">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">{t('admin.title')}</h1>
        <p class="mt-1 text-text-secondary">欢迎回来，{user.fullName || user.username}</p>
      </div>
      <a
        href="/admin/articles/new"
        class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        {t('dashboard.newArticle')}
      </a>
    </div>

    {/* Stats */}
    <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map(stat => (
        <div class="rounded-xl border border-border bg-card p-6">
          <div class="flex items-center justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
              {stat.icon === 'document' && (
                <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              )}
              {stat.icon === 'users' && (
                <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" /></svg>
              )}
              {stat.icon === 'chart-bar' && (
                <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
              )}
              {stat.icon === 'rss' && (
                <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
              )}
            </div>
            <span class="text-xs text-success">{stat.change}</span>
          </div>
          <p class="mt-4 text-2xl font-bold text-text-primary">{stat.value}</p>
          <p class="text-sm text-text-secondary">{stat.label}</p>
        </div>
      ))}
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      {/* Recent Articles */}
      <div class="lg:col-span-2">
        <div class="rounded-xl border border-border bg-card">
          <div class="flex items-center justify-between border-b border-border p-4">
            <h2 class="font-semibold text-text-primary">最近文章</h2>
            <a href="/admin/articles" class="text-sm text-accent hover:underline">查看全部</a>
          </div>
          <div class="divide-y divide-border">
            {recentArticles.map(article => (
              <div class="flex items-center justify-between p-4">
                <div class="flex-1">
                  <p class="text-sm font-medium text-text-primary">{article.title}</p>
                  <p class="text-xs text-text-tertiary">{article.date}</p>
                </div>
                <div class="flex items-center gap-4">
                  {article.views > 0 && (
                    <span class="text-xs text-text-tertiary">{article.views.toLocaleString()} 阅读</span>
                  )}
                  <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${statusColors[article.status]}`}>
                    {statusLabels[article.status]}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Sidebar */}
      <div class="space-y-6">
        {/* Quick Links */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 font-semibold text-text-primary">快速操作</h3>
          <div class="space-y-2">
            <a href="/admin/articles" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              文章管理
            </a>
            <a href="/admin/feeds" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
              RSS 源管理
            </a>
            <a href="/admin/categories" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" /></svg>
              分类管理
            </a>
            <a href="/admin/users" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" /></svg>
              用户管理
            </a>
          </div>
        </div>

        {/* System Info */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 font-semibold text-text-primary">系统信息</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-text-secondary">版本</span>
              <span class="text-text-primary">v0.1.0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-text-secondary">数据库状态</span>
              <span class="text-success">正常</span>
            </div>
            <div class="flex justify-between">
              <span class="text-text-secondary">最后同步</span>
              <span class="text-text-primary">5 分钟前</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
