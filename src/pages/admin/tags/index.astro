---
// src/pages/admin/tags/index.astro
// 功能：标签管理页面 — 标签列表、新增/编辑/删除标签
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/login');
}
---

<AdminLayout>
  <div class="px-4 py-8 md:px-8">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">{t('admin.tags')}</h1>
        <p class="mt-1 text-text-secondary">管理文章标签</p>
      </div>
      <button
        id="btn-add"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"
          ></path></svg
        >
        新增标签
      </button>
    </div>

    <div class="rounded-xl border border-border bg-card">
      <div id="tag-list" class="divide-y divide-border">
        <div class="p-8 text-center text-text-tertiary">加载中...</div>
      </div>
    </div>

    {/* 编辑弹窗 */}
    <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
      <div class="w-full max-w-sm rounded-xl border border-border bg-background p-6">
        <h2 id="modal-title" class="mb-4 text-lg font-bold text-text-primary">新增标签</h2>
        <form id="tag-form" class="space-y-4">
          <input type="hidden" id="edit-id" />
          <div>
            <label for="edit-name" class="mb-1 block text-xs text-text-secondary">名称</label>
            <input
              type="text"
              id="edit-name"
              required
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>
          <div>
            <label for="edit-slug" class="mb-1 block text-xs text-text-secondary">标识 (slug)</label
            >
            <input
              type="text"
              id="edit-slug"
              required
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>
          <div class="flex justify-end gap-2 pt-2">
            <button
              type="button"
              id="btn-cancel"
              class="rounded-lg border border-border px-4 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover"
              >取消</button
            >
            <button
              type="submit"
              class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
              >保存</button
            >
          </div>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  function getEl<T extends HTMLElement = HTMLElement>(id: string): T {
    return document.getElementById(id) as T;
  }

  const modal = getEl('modal');
  const form = getEl<HTMLFormElement>('tag-form');
  let editingId: string | null = null;

  function openModal(tag?: any) {
    editingId = tag?.id || null;
    getEl('modal-title').textContent = tag ? '编辑标签' : '新增标签';
    getEl<HTMLInputElement>('edit-id').value = tag?.id || '';
    getEl<HTMLInputElement>('edit-name').value = tag?.name || '';
    getEl<HTMLInputElement>('edit-slug').value = tag?.slug || '';
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  async function loadTags() {
    try {
      const res = await fetch('/api/tags');
      const data = await res.json();
      const list = getEl('tag-list');

      if (!data.tags || data.tags.length === 0) {
        list.innerHTML = `<div class="p-8 text-center text-text-tertiary">暂无标签</div>`;
        return;
      }

      list.innerHTML = data.tags
        .map(
          (tag: any) => `
        <div class="flex items-center justify-between px-4 py-3 hover:bg-background-hover">
          <div class="flex items-center gap-3">
            <svg class="h-4 w-4 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" /></svg>
            <div>
              <span class="text-sm font-medium text-text-primary">${tag.name}</span>
              <span class="ml-2 rounded bg-background-hover px-1.5 py-0.5 text-xs text-text-tertiary">${tag.slug}</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <button data-edit='${JSON.stringify(tag)}' class="edit-btn rounded p-1 text-text-tertiary transition-colors hover:bg-background-hover hover:text-text-primary">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            </button>
            <button data-delete="${tag.id}" class="delete-btn rounded p-1 text-text-tertiary transition-colors hover:bg-background-hover hover:text-error">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            </button>
          </div>
        </div>
      `
        )
        .join('');

      list.querySelectorAll('.edit-btn').forEach((btn) => {
        btn.addEventListener('click', () =>
          openModal(JSON.parse((btn as HTMLElement).dataset.edit!))
        );
      });

      list.querySelectorAll('.delete-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          if (!confirm('确定删除此标签？')) return;
          await fetch('/api/tags', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: (btn as HTMLElement).dataset.delete }),
          });
          loadTags();
        });
      });
    } catch {
      getEl('tag-list').innerHTML = `<div class="p-8 text-center text-error">加载失败</div>`;
    }
  }

  getEl('btn-add')?.addEventListener('click', () => openModal());
  getEl('btn-cancel')?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const body = {
      id: editingId || undefined,
      name: getEl<HTMLInputElement>('edit-name').value,
      slug: getEl<HTMLInputElement>('edit-slug').value,
    };
    const method = editingId ? 'PUT' : 'POST';
    const res = await fetch('/api/tags', {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();
    if (data.success) {
      closeModal();
      loadTags();
    } else alert(data.error || '操作失败');
  });

  loadTags();
</script>
