---
// src/pages/dashboard/bookmarks/index.astro
// 功能：我的收藏页面（中文） — 展示用户收藏的文章列表
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(getLocalizedPath('/login', lang));
}
---

<BaseLayout title={t('dashboard.bookmarks.title')}>
  <div class="mx-auto max-w-5xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-text-primary">{t('dashboard.bookmarks.title')}</h1>
      <p class="mt-1 text-text-secondary">管理你收藏的文章</p>
    </div>

    <div class="rounded-xl border border-border bg-card p-6">
      <div id="bookmarks-loading" class="py-8 text-center text-text-secondary">
        {t('common.loading')}
      </div>

      <div id="bookmarks-empty" class="hidden py-8 text-center text-text-secondary">
        <svg
          class="mx-auto mb-4 h-12 w-12 text-text-tertiary"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path>
        </svg>
        <p>{t('dashboard.bookmarks.empty')}</p>
      </div>

      <div id="bookmarks-list" class="hidden divide-y divide-border"></div>
    </div>
  </div>
</BaseLayout>

<script>
  function getEl<T extends HTMLElement = HTMLElement>(id: string): T {
    return document.getElementById(id) as T;
  }

  interface Bookmark {
    id: string;
    title: string;
    slug: string;
    source: string;
    createdAt: string;
  }

  async function loadBookmarks() {
    const loading = getEl('bookmarks-loading');
    const empty = getEl('bookmarks-empty');
    const list = getEl('bookmarks-list');

    try {
      const res = await fetch('/api/user/bookmarks');
      if (!res.ok) throw new Error('Failed to fetch');
      const data: Bookmark[] = await res.json();

      loading.classList.add('hidden');

      if (!data || data.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      list.innerHTML = data
        .map(
          (b) => `
          <a href="/news/${b.slug}" class="flex items-center justify-between px-4 py-3 transition-colors hover:bg-background-hover">
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium text-text-primary">${b.title}</p>
              <p class="mt-0.5 text-xs text-text-tertiary">${b.source || ''}</p>
            </div>
            <span class="ml-4 shrink-0 text-xs text-text-tertiary">${new Date(b.createdAt).toLocaleDateString('zh-CN')}</span>
          </a>`
        )
        .join('');

      list.classList.remove('hidden');
    } catch {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  loadBookmarks();
</script>
