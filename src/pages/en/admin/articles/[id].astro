---
// src/pages/en/admin/articles/[id].astro
// 功能：Article editor page — Create/edit articles
import AdminLayout from '@/layouts/AdminLayout.astro';
import TiptapEditor from '@/components/editor/TiptapEditor';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;
const isNew = id === 'new';
---

<AdminLayout>
  <div class="px-4 py-8 md:px-8">
    <div class="mb-8 flex items-center gap-4">
      <a
        href="/en/admin/articles"
        class="rounded-lg p-2 text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
        >
      </a>
      <div>
        <h1 class="text-2xl font-bold text-text-primary">
          {isNew ? 'Publish Article' : 'Edit Article'}
        </h1>
        <p class="mt-1 text-text-secondary">
          {isNew ? 'Create new article content' : 'Modify article content and settings'}
        </p>
      </div>
    </div>

    <form id="article-form" class="grid gap-6 lg:grid-cols-3">
      {/* Main content area */}
      <div class="space-y-6 lg:col-span-2">
        <div class="rounded-xl border border-border bg-card p-6">
          <label for="title" class="mb-2 block text-sm font-medium text-text-primary">Title</label>
          <input
            type="text"
            id="title"
            name="title"
            required
            placeholder="Enter article title..."
            class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-text-primary placeholder-text-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
          />
        </div>

        <div class="rounded-xl border border-border bg-card p-6">
          <label for="content" class="mb-2 block text-sm font-medium text-text-primary"
            >Content</label
          >
          <input type="hidden" id="content" name="content" value="" />
          <TiptapEditor
            client:load
            content=""
            placeholder="Start writing article content..."
            onChange={(html) => {
              (document.getElementById('content') as HTMLInputElement).value = html;
            }}
          />
        </div>

        <div class="rounded-xl border border-border bg-card p-6">
          <label for="excerpt" class="mb-2 block text-sm font-medium text-text-primary"
            >Excerpt</label
          >
          <textarea
            id="excerpt"
            name="excerpt"
            rows="3"
            placeholder="Brief article summary..."
            class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-text-primary placeholder-text-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
          ></textarea>
        </div>
      </div>

      {/* Sidebar */}
      <div class="space-y-6">
        {/* Status */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 text-sm font-medium text-text-primary">Publish Settings</h3>
          <div class="space-y-4">
            <div>
              <label for="status" class="mb-1 block text-xs text-text-secondary">Status</label>
              <select
                id="status"
                name="status"
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              >
                <option value="draft">Draft</option>
                <option value="published">Published</option>
                <option value="archived">Archived</option>
              </select>
            </div>
            <div>
              <label for="category" class="mb-1 block text-xs text-text-secondary">Category</label>
              <select
                id="category"
                name="categoryId"
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              >
                <option value="">No category</option>
              </select>
            </div>
            <div>
              <label for="lang" class="mb-1 block text-xs text-text-secondary">Language</label>
              <select
                id="lang"
                name="lang"
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              >
                <option value="zh">Chinese</option>
                <option value="en">English</option>
              </select>
            </div>
          </div>
        </div>

        {/* Tags */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 text-sm font-medium text-text-primary">Tags</h3>
          <div id="tags-list" class="space-y-2">
            <p class="text-xs text-text-tertiary">Loading...</p>
          </div>
        </div>

        {/* Cover Image */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 text-sm font-medium text-text-primary">Cover Image</h3>
          <div id="cover-preview" class="mb-3 hidden">
            <img
              id="cover-preview-img"
              src=""
              alt=""
              class="w-full rounded-lg object-cover"
              style="max-height:160px;"
            />
            <button type="button" id="cover-remove" class="mt-2 text-xs text-error hover:underline"
              >Remove cover</button
            >
          </div>
          <div class="space-y-2">
            <label
              for="cover-upload"
              class="flex w-full cursor-pointer items-center justify-center gap-2 rounded-lg border border-dashed border-border bg-background px-4 py-3 text-sm text-text-secondary transition-colors hover:border-accent hover:text-accent"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path></svg
              >
              Upload cover image
            </label>
            <input type="file" id="cover-upload" accept="image/*" class="hidden" />
            <div class="relative">
              <input
                type="url"
                id="coverImage"
                name="coverImage"
                placeholder="Or enter image URL: https://..."
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary placeholder-text-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              />
            </div>
          </div>
        </div>

        {/* Action buttons */}
        <div class="rounded-xl border border-border bg-card p-6">
          <div class="space-y-2">
            <button
              type="submit"
              id="btn-save"
              class="w-full rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
            >
              {isNew ? 'Save Draft' : 'Save Changes'}
            </button>
            <button
              type="button"
              id="btn-publish"
              class="w-full rounded-lg border border-accent px-4 py-2 text-sm font-medium text-accent transition-colors hover:bg-accent/10"
            >
              Publish Now
            </button>
            {
              !isNew && (
                <button
                  type="button"
                  id="btn-delete"
                  class="w-full rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary transition-colors hover:border-error hover:text-error"
                >
                  Delete Article
                </button>
              )
            }
          </div>
        </div>
      </div>
    </form>
  </div>
</AdminLayout>

<script is:inline define:vars={{ id, isNew }}>
  let articleId = isNew ? null : id;

  async function loadCategories() {
    try {
      const res = await fetch('/api/categories');
      if (res.ok) {
        const data = await res.json();
        const select = document.getElementById('category');
        data.categories?.forEach((c) => {
          const opt = document.createElement('option');
          opt.value = c.id;
          opt.textContent = c.name;
          select.appendChild(opt);
        });
      }
    } catch {
      // ignore
    }
  }

  async function loadTags() {
    try {
      const res = await fetch('/api/tags');
      if (res.ok) {
        const data = await res.json();
        const listEl = document.getElementById('tags-list');
        if (data.tags && data.tags.length > 0) {
          listEl.innerHTML = data.tags
            .map(
              (tag) => `
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" value="${tag.id}" class="tag-checkbox h-4 w-4 rounded border-border accent-accent" />
              <span class="text-sm text-text-secondary">${tag.name}</span>
            </label>
          `
            )
            .join('');
        } else {
          listEl.innerHTML = '<p class="text-xs text-text-tertiary">No tags</p>';
        }
      }
    } catch {
      /* ignore */
    }
  }

  function getSelectedTagIds() {
    return Array.from(document.querySelectorAll('.tag-checkbox:checked')).map((cb) => cb.value);
  }

  async function loadArticle() {
    if (isNew || !articleId) return;
    try {
      const res = await fetch(`/api/articles/by-id/${articleId}`);
      const data = await res.json();
      const a = data.article;
      document.getElementById('title').value = a.title || '';
      document.getElementById('content').value = a.content || '';
      window.dispatchEvent(
        new CustomEvent('tiptap-set-content', { detail: { html: a.content || '' } })
      );
      document.getElementById('excerpt').value = a.excerpt || '';
      document.getElementById('status').value = a.status || 'draft';
      document.getElementById('lang').value = a.lang || 'zh';
      document.getElementById('coverImage').value = a.coverImage || '';
      if (a.coverImage) {
        document.getElementById('cover-preview-img').src = a.coverImage;
        document.getElementById('cover-preview').classList.remove('hidden');
      }
      if (a.categoryId) document.getElementById('category').value = a.categoryId;
      if (a.tagIds && a.tagIds.length > 0) {
        document.querySelectorAll('.tag-checkbox').forEach((cb) => {
          cb.checked = a.tagIds.includes(cb.value);
        });
      }
    } catch {
      alert('Failed to load article');
    }
  }

  async function saveArticle(statusOverride) {
    const title = document.getElementById('title').value.trim();
    if (!title) {
      alert('Title cannot be empty');
      return;
    }

    const body = {
      title,
      content: document.getElementById('content').value,
      excerpt: document.getElementById('excerpt').value,
      categoryId: document.getElementById('category').value || undefined,
      lang: document.getElementById('lang').value,
      status: statusOverride || document.getElementById('status').value,
      coverImage: document.getElementById('coverImage').value || undefined,
      tagIds: getSelectedTagIds(),
    };

    try {
      let res;
      if (isNew) {
        res = await fetch('/api/articles/new', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
      } else {
        body.id = articleId;
        res = await fetch(`/api/articles/by-id/${articleId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
      }
      const data = await res.json();
      if (data.success) {
        if (isNew && data.id) articleId = data.id;
        alert('Saved successfully');
        if (!isNew) loadArticle();
      } else {
        alert(data.error || 'Failed to save');
      }
    } catch {
      alert('Failed to save');
    }
  }

  const coverUpload = document.getElementById('cover-upload');
  const coverPreview = document.getElementById('cover-preview');
  const coverPreviewImg = document.getElementById('cover-preview-img');
  const coverInput = document.getElementById('coverImage');
  const coverRemove = document.getElementById('cover-remove');

  coverUpload?.addEventListener('change', async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const formData = new FormData();
    formData.append('cover', file);
    try {
      const res = await fetch('/api/articles/upload-cover', { method: 'POST', body: formData });
      const data = await res.json();
      if (res.ok && data.url) {
        coverInput.value = data.url;
        coverPreviewImg.src = data.url;
        coverPreview.classList.remove('hidden');
      } else {
        alert(data.error || 'Upload failed');
      }
    } catch {
      alert('Upload failed');
    }
    coverUpload.value = '';
  });

  coverRemove?.addEventListener('click', () => {
    coverInput.value = '';
    coverPreview.classList.add('hidden');
    coverPreviewImg.src = '';
  });

  document.getElementById('article-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    saveArticle();
  });
  document.getElementById('btn-publish')?.addEventListener('click', () => saveArticle('published'));
  document.getElementById('btn-delete')?.addEventListener('click', async () => {
    if (!confirm('Are you sure you want to delete this article?')) return;
    try {
      const res = await fetch(`/api/articles/by-id/${articleId}`, {
        method: 'DELETE',
      });
      const data = await res.json();
      if (data.success) window.location.href = '/en/admin/articles';
      else alert(data.error || 'Failed to delete');
    } catch {
      alert('Failed to delete');
    }
  });

  loadCategories();
  loadTags();
  loadArticle();
</script>
