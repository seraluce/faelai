---
// src/pages/en/admin/articles/index.astro
// 功能：文章管理页面（英文） — 文章列表、状态筛选、搜索、批量操作、分页
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/login');
}
---

<AdminLayout>
  <div class="px-4 py-8 md:px-8">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">{t('admin.articles')}</h1>
        <p class="mt-1 text-text-secondary">Manage all articles</p>
      </div>
      <a
        href="/admin/articles/new"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"
          ></path></svg
        >
        New Article
      </a>
    </div>

    {/* Search and filters */}
    <div class="mb-6 flex flex-col gap-4 sm:flex-row">
      <div class="relative flex-1">
        <svg
          class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-text-tertiary"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg
        >
        <input
          type="text"
          id="search-input"
          placeholder="Search articles..."
          class="w-full rounded-lg border border-border bg-background py-2 pl-10 pr-4 text-sm text-text-primary placeholder-text-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
        />
      </div>
      <select
        id="status-filter"
        class="rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
      >
        <option value="">All Status</option>
        <option value="published">Published</option>
        <option value="draft">Draft</option>
        <option value="archived">Archived</option>
      </select>
      <select
        id="lang-filter"
        class="rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
      >
        <option value="">All Languages</option>
        <option value="zh">中文</option>
        <option value="en">English</option>
      </select>
    </div>

    {/* Article list */}
    <div class="rounded-xl border border-border bg-card">
      <div class="border-b border-border px-4 py-3">
        <div class="flex items-center justify-between">
          <span id="article-count" class="text-sm text-text-secondary">Loading...</span>
          <div class="flex items-center gap-2">
            <button
              id="btn-delete-selected"
              class="hidden rounded-lg border border-border px-3 py-1.5 text-xs text-text-secondary transition-colors hover:border-error hover:text-error"
            >
              Delete Selected
            </button>
          </div>
        </div>
      </div>
      <div id="article-list" class="divide-y divide-border">
        <div class="p-8 text-center text-text-tertiary">Loading...</div>
      </div>
      {/* Pagination */}
      <div id="pagination" class="border-t border-border px-4 py-3"></div>
    </div>
  </div>
</AdminLayout>

<script>
  function getEl<T extends HTMLElement = HTMLElement>(id: string): T {
    return document.getElementById(id) as T;
  }

  interface Article {
    id: string;
    title: string;
    status: string;
    author?: string;
    publishedAt?: string;
    createdAt: string;
    viewCount?: number;
  }

  let currentPage = 1;
  const limit = 20;
  const selectedIds: Set<string> = new Set();

  async function loadArticles() {
    const search = getEl<HTMLInputElement>('search-input').value || '';
    const status = getEl<HTMLSelectElement>('status-filter').value || '';
    const lang = getEl<HTMLSelectElement>('lang-filter').value || '';

    const params = new URLSearchParams({ page: String(currentPage), limit: String(limit) });
    if (search) params.set('search', search);
    if (status) params.set('status', status);
    if (lang) params.set('lang', lang);

    try {
      const res = await fetch(`/api/articles?${params}`);
      const data = await res.json();
      const { articles, pagination } = data;

      getEl('article-count').textContent = `Total ${pagination.total} articles`;
      const listEl = getEl('article-list');

      if (!articles || articles.length === 0) {
        listEl.innerHTML = `<div class="p-8 text-center text-text-tertiary">No articles yet</div>`;
        getEl('pagination').innerHTML = '';
        return;
      }

      listEl.innerHTML = articles
        .map((a: Article) => {
          const statusClass =
            a.status === 'published'
              ? 'bg-success/10 text-success'
              : a.status === 'draft'
                ? 'bg-warning/10 text-warning'
                : 'bg-text-tertiary/10 text-text-tertiary';
          const statusLabel =
            a.status === 'published' ? 'Published' : a.status === 'draft' ? 'Draft' : 'Archived';
          const date = a.publishedAt
            ? new Date(a.publishedAt).toLocaleDateString('en-US')
            : new Date(a.createdAt).toLocaleDateString('en-US');
          return `
          <div class="flex items-center gap-4 px-4 py-3 hover:bg-background-hover">
            <input type="checkbox" data-id="${a.id}" class="article-checkbox h-4 w-4 rounded border-border accent-accent" />
            <div class="min-w-0 flex-1">
              <a href="/admin/articles/${a.id}" class="text-sm font-medium text-text-primary hover:text-accent">${a.title}</a>
              <div class="mt-1 flex items-center gap-3 text-xs text-text-tertiary">
                <span>${a.author || 'Unknown'}</span>
                <span>${date}</span>
                ${a.viewCount ? `<span>${a.viewCount} views</span>` : ''}
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="rounded-full px-2 py-0.5 text-xs font-medium ${statusClass}">${statusLabel}</span>
              <a href="/admin/articles/${a.id}" class="rounded p-1 text-text-tertiary transition-colors hover:bg-background-hover hover:text-text-primary">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
              </a>
            </div>
          </div>
        `;
        })
        .join('');

      // Checkbox events
      listEl.querySelectorAll('.article-checkbox').forEach((cb) => {
        const input = cb as HTMLInputElement;
        input.addEventListener('change', () => {
          const id = input.dataset.id;
          if (id) {
            if (input.checked) selectedIds.add(id);
            else selectedIds.delete(id);
          }
          getEl('btn-delete-selected').classList.toggle('hidden', selectedIds.size === 0);
        });
      });

      // Pagination
      const paginationEl = getEl('pagination');
      if (pagination.totalPages > 1) {
        let pages = '';
        for (let i = 1; i <= pagination.totalPages; i++) {
          pages += `<button data-page="${i}" class="rounded px-3 py-1 text-sm ${i === currentPage ? 'bg-accent text-white' : 'text-text-secondary hover:bg-background-hover'}">${i}</button>`;
        }
        paginationEl.innerHTML = `<div class="flex items-center justify-center gap-1">${pages}</div>`;
        paginationEl.querySelectorAll('button').forEach((btn) => {
          const el = btn as HTMLElement;
          el.addEventListener('click', () => {
            currentPage = parseInt(el.dataset.page || '1');
            loadArticles();
          });
        });
      } else {
        paginationEl.innerHTML = '';
      }
    } catch {
      getEl('article-list').innerHTML =
        `<div class="p-8 text-center text-error">Failed to load</div>`;
    }
  }

  getEl<HTMLInputElement>('search-input').addEventListener('input', () => {
    currentPage = 1;
    loadArticles();
  });
  getEl<HTMLSelectElement>('status-filter').addEventListener('change', () => {
    currentPage = 1;
    loadArticles();
  });
  getEl<HTMLSelectElement>('lang-filter').addEventListener('change', () => {
    currentPage = 1;
    loadArticles();
  });

  getEl('btn-delete-selected').addEventListener('click', async () => {
    if (!confirm(`Delete ${selectedIds.size} articles?`)) return;
    for (const id of selectedIds) {
      await fetch(`/api/articles/by-id/${id}`, {
        method: 'DELETE',
      });
    }
    selectedIds.clear();
    loadArticles();
  });

  loadArticles();
</script>
