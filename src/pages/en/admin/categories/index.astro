---
// src/pages/en/admin/categories/index.astro
// 功能：分类管理页面（英文） — 分类列表、新增/编辑/删除分类
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/login');
}
---

<AdminLayout>
  <div class="px-4 py-8 md:px-8">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">{t('admin.categories')}</h1>
        <p class="mt-1 text-text-secondary">Manage article categories</p>
      </div>
      <button
        id="btn-add"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"
          ></path></svg
        >
        Add Category
      </button>
    </div>

    {/* Category list */}
    <div class="rounded-xl border border-border bg-card">
      <div id="category-list" class="divide-y divide-border">
        <div class="p-8 text-center text-text-tertiary">Loading...</div>
      </div>
    </div>

    {/* Edit modal */}
    <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
      <div class="w-full max-w-md rounded-xl border border-border bg-background p-6">
        <h2 id="modal-title" class="mb-4 text-lg font-bold text-text-primary">Add Category</h2>
        <form id="category-form" class="space-y-4">
          <input type="hidden" id="edit-id" />
          <div>
            <label for="edit-name" class="mb-1 block text-xs text-text-secondary">Name</label>
            <input
              type="text"
              id="edit-name"
              required
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>
          <div>
            <label for="edit-nameEn" class="mb-1 block text-xs text-text-secondary"
              >English Name</label
            >
            <input
              type="text"
              id="edit-nameEn"
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>
          <div>
            <label for="edit-slug" class="mb-1 block text-xs text-text-secondary">Slug</label>
            <input
              type="text"
              id="edit-slug"
              required
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            />
          </div>
          <div>
            <label for="edit-description" class="mb-1 block text-xs text-text-secondary"
              >Description</label
            >
            <textarea
              id="edit-description"
              rows="2"
              class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            ></textarea>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="edit-color" class="mb-1 block text-xs text-text-secondary">Color</label>
              <input
                type="color"
                id="edit-color"
                value="#0070f3"
                class="h-9 w-full cursor-pointer rounded-lg border border-border bg-background"
              />
            </div>
            <div>
              <label for="edit-sortOrder" class="mb-1 block text-xs text-text-secondary"
                >Sort Order</label
              >
              <input
                type="number"
                id="edit-sortOrder"
                value="0"
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              />
            </div>
          </div>
          <div class="flex justify-end gap-2 pt-2">
            <button
              type="button"
              id="btn-cancel"
              class="rounded-lg border border-border px-4 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover"
              >Cancel</button
            >
            <button
              type="submit"
              class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
              >Save</button
            >
          </div>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  function getEl<T extends HTMLElement = HTMLElement>(id: string): T {
    return document.getElementById(id) as T;
  }

  const modal = getEl('modal');
  const form = getEl<HTMLFormElement>('category-form');
  let editingId: string | null = null;

  interface CategoryData {
    id?: string;
    name?: string;
    nameEn?: string;
    slug?: string;
    description?: string;
    color?: string;
    sortOrder?: number;
  }

  function openModal(category?: CategoryData) {
    editingId = category?.id || null;
    getEl('modal-title').textContent = category ? 'Edit Category' : 'Add Category';
    getEl<HTMLInputElement>('edit-id').value = category?.id || '';
    getEl<HTMLInputElement>('edit-name').value = category?.name || '';
    getEl<HTMLInputElement>('edit-nameEn').value = category?.nameEn || '';
    getEl<HTMLInputElement>('edit-slug').value = category?.slug || '';
    getEl<HTMLTextAreaElement>('edit-description').value = category?.description || '';
    getEl<HTMLInputElement>('edit-color').value = category?.color || '#0070f3';
    getEl<HTMLInputElement>('edit-sortOrder').value = String(category?.sortOrder ?? 0);
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  async function loadCategories() {
    try {
      const res = await fetch('/api/categories');
      const data = await res.json();
      const list = getEl('category-list');

      if (!data.categories || data.categories.length === 0) {
        list.innerHTML = `<div class="p-8 text-center text-text-tertiary">No categories yet</div>`;
        return;
      }

      list.innerHTML = data.categories
        .map(
          (c: { color: string; name: string; nameEn: string; slug: string; id: string }) => `
        <div class="flex items-center justify-between px-4 py-3 hover:bg-background-hover">
          <div class="flex items-center gap-3">
            <div class="h-3 w-3 rounded-full" style="background-color: ${c.color || '#0070f3'}"></div>
            <div>
              <span class="text-sm font-medium text-text-primary">${c.name}</span>
              ${c.nameEn ? `<span class="ml-2 text-xs text-text-tertiary">${c.nameEn}</span>` : ''}
              <span class="ml-2 rounded bg-background-hover px-1.5 py-0.5 text-xs text-text-tertiary">${c.slug}</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <button data-edit='${JSON.stringify(c)}' class="edit-btn rounded p-1 text-text-tertiary transition-colors hover:bg-background-hover hover:text-text-primary">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            </button>
            <button data-delete="${c.id}" class="delete-btn rounded p-1 text-text-tertiary transition-colors hover:bg-background-hover hover:text-error">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            </button>
          </div>
        </div>
      `
        )
        .join('');

      list.querySelectorAll('.edit-btn').forEach((btn) => {
        (btn as HTMLElement).addEventListener('click', () =>
          openModal(JSON.parse((btn as HTMLElement).dataset.edit!))
        );
      });

      list.querySelectorAll('.delete-btn').forEach((btn) => {
        (btn as HTMLElement).addEventListener('click', async () => {
          if (!confirm('Are you sure you want to delete this category?')) return;
          await fetch('/api/categories', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: (btn as HTMLElement).dataset.delete }),
          });
          loadCategories();
        });
      });
    } catch {
      getEl('category-list').innerHTML =
        `<div class="p-8 text-center text-error">Failed to load</div>`;
    }
  }

  getEl('btn-add')?.addEventListener('click', () => openModal());
  getEl('btn-cancel')?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const body = {
      id: editingId || undefined,
      name: getEl<HTMLInputElement>('edit-name').value,
      nameEn: getEl<HTMLInputElement>('edit-nameEn').value || undefined,
      slug: getEl<HTMLInputElement>('edit-slug').value,
      description: getEl<HTMLTextAreaElement>('edit-description').value || undefined,
      color: getEl<HTMLInputElement>('edit-color').value,
      sortOrder: parseInt(getEl<HTMLInputElement>('edit-sortOrder').value) || 0,
    };

    const method = editingId ? 'PUT' : 'POST';
    const res = await fetch('/api/categories', {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();
    if (data.success) {
      closeModal();
      loadCategories();
    } else alert(data.error || 'Operation failed');
  });

  loadCategories();
</script>
