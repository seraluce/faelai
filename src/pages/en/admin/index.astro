---
// src/pages/en/admin/index.astro
// 功能：管理后台仪表盘（英文） — 系统统计、最近文章、快速操作、系统信息
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { db, schema } from '@/lib/db';
import { eq, desc, sql } from 'drizzle-orm';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/${lang}/login`);
}

const [{ count: totalArticles }] = await db
  .select({ count: sql<number>`count(*)` })
  .from(schema.articles);
const [{ count: publishedArticles }] = await db
  .select({ count: sql<number>`count(*)` })
  .from(schema.articles)
  .where(eq(schema.articles.status, 'published'));
const [{ count: totalUsers }] = await db
  .select({ count: sql<number>`count(*)` })
  .from(schema.users);
const [{ count: totalFeeds }] = await db
  .select({ count: sql<number>`count(*)` })
  .from(schema.feeds);
const [{ count: totalCategories }] = await db
  .select({ count: sql<number>`count(*)` })
  .from(schema.categories);

const recentArticles = await db
  .select()
  .from(schema.articles)
  .orderBy(desc(schema.articles.createdAt))
  .limit(5);

const stats = [
  { label: 'Total Articles', value: totalArticles.toLocaleString(), icon: 'document' },
  { label: 'Published', value: publishedArticles.toLocaleString(), icon: 'chart-bar' },
  { label: 'Total Users', value: totalUsers.toLocaleString(), icon: 'users' },
  { label: 'RSS Feeds', value: totalFeeds.toLocaleString(), icon: 'rss' },
];

const statusColors: Record<string, string> = {
  published: 'bg-success/10 text-success',
  draft: 'bg-warning/10 text-warning',
  archived: 'bg-accent/10 text-accent',
};

const statusLabels: Record<string, string> = {
  published: 'Published',
  draft: 'Draft',
  archived: 'Archived',
};

function timeAgo(date: Date | null): string {
  if (!date) return '';
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const minutes = Math.floor(diff / 60000);
  if (minutes < 1) return 'Just now';
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
}
---

<AdminLayout>
  <div class="px-4 py-8 md:px-8">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-text-primary">{t('admin.title')}</h1>
        <p class="mt-1 text-text-secondary">Welcome back, {user.fullName || user.username}</p>
      </div>
      <a
        href="/en/admin/articles/new"
        class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        {t('dashboard.newArticle')}
      </a>
    </div>

    {/* Stats */}
    <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        stats.map((stat) => (
          <div class="rounded-xl border border-border bg-card p-6">
            <div class="flex items-center justify-between">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
                {stat.icon === 'document' && (
                  <svg
                    class="h-5 w-5 text-accent"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                    />
                  </svg>
                )}
                {stat.icon === 'users' && (
                  <svg
                    class="h-5 w-5 text-accent"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"
                    />
                  </svg>
                )}
                {stat.icon === 'chart-bar' && (
                  <svg
                    class="h-5 w-5 text-accent"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                    />
                  </svg>
                )}
                {stat.icon === 'rss' && (
                  <svg
                    class="h-5 w-5 text-accent"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"
                    />
                  </svg>
                )}
              </div>
            </div>
            <p class="mt-4 text-2xl font-bold text-text-primary">{stat.value}</p>
            <p class="text-sm text-text-secondary">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      {/* Recent Articles */}
      <div class="lg:col-span-2">
        <div class="rounded-xl border border-border bg-card">
          <div class="flex items-center justify-between border-b border-border p-4">
            <h2 class="font-semibold text-text-primary">Recent Articles</h2>
            <a href="/en/admin/articles" class="text-sm text-accent hover:underline">View All</a>
          </div>
          <div class="divide-y divide-border">
            {
              recentArticles.length > 0 ? (
                recentArticles.map((article) => (
                  <div class="flex items-center justify-between p-4">
                    <div class="flex-1">
                      <p class="text-sm font-medium text-text-primary">{article.title}</p>
                      <p class="text-xs text-text-tertiary">{timeAgo(article.createdAt)}</p>
                    </div>
                    <div class="flex items-center gap-4">
                      {(article.viewCount ?? 0) > 0 && (
                        <span class="text-xs text-text-tertiary">
                          {(article.viewCount ?? 0).toLocaleString()} views
                        </span>
                      )}
                      <span
                        class={`rounded-full px-2 py-0.5 text-xs font-medium ${statusColors[article.status] || ''}`}
                      >
                        {statusLabels[article.status] || article.status}
                      </span>
                    </div>
                  </div>
                ))
              ) : (
                <div class="p-4 text-sm text-text-tertiary">No articles yet</div>
              )
            }
          </div>
        </div>
      </div>

      {/* Sidebar */}
      <div class="space-y-6">
        {/* Quick Links */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 font-semibold text-text-primary">Quick Actions</h3>
          <div class="space-y-2">
            <a
              href="/en/admin/articles"
              class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path></svg
              >
              Articles
            </a>
            <a
              href="/en/admin/feeds"
              class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"
                ></path></svg
              >
              RSS Feeds
            </a>
            <a
              href="/en/admin/categories"
              class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"
                ></path></svg
              >
              Categories
            </a>
            <a
              href="/en/admin/users"
              class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"
                ></path></svg
              >
              Users
            </a>
          </div>
        </div>

        {/* System Info */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 font-semibold text-text-primary">System Info</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-text-secondary">Version</span>
              <span class="text-text-primary">FaelAI v1.0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-text-secondary">Database</span>
              <span class="text-success">Healthy</span>
            </div>
            <div class="flex justify-between">
              <span class="text-text-secondary">Categories</span>
              <span class="text-text-primary">{totalCategories}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
