---
// src/pages/en/admin/settings/index.astro
// 功能：系统设置页面（英文版）— 站点信息编辑、系统状态、数据统计、快捷操作
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { db, schema } from '@/lib/db';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/en/login');
}

const settingsRows = await db.select().from(schema.siteSettings);
const settings: Record<string, string> = {};
for (const row of settingsRows) {
  if (row.value !== null) settings[row.key] = row.value;
}
---

<AdminLayout>
  <div class="px-4 py-8 md:px-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-text-primary">{t('admin.settings')}</h1>
      <p class="mt-1 text-text-secondary">System configuration and information</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {/* Site Info */}
      <div class="rounded-xl border border-border bg-card p-6">
        <h2 class="mb-4 text-lg font-semibold text-text-primary">Site Information</h2>
        <form id="settings-form" class="space-y-4">
          <div>
            <label class="mb-1 block text-sm font-medium text-text-secondary">Site Name</label>
            <input
              type="text"
              id="site-name"
              value={settings.siteName || 'FaelAI'}
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-text-primary focus:border-accent focus:outline-none"
            />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-text-secondary"
              >Site Description</label
            >
            <textarea
              id="site-description"
              rows="2"
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-text-primary focus:border-accent focus:outline-none"
              >{settings.siteDescription || 'AI News Aggregation Platform'}</textarea
            >
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-text-secondary">Site URL</label>
            <input
              type="url"
              id="site-url"
              value={settings.siteUrl || ''}
              placeholder="https://faelai.com"
              class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-text-primary placeholder-text-tertiary focus:border-accent focus:outline-none"
            />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="mb-1 block text-sm font-medium text-text-secondary"
                >Default Language</label
              >
              <select
                id="site-lang"
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none"
              >
                <option value="zh" selected={settings.siteLang !== 'en'}>Chinese</option>
                <option value="en" selected={settings.siteLang === 'en'}>English</option>
              </select>
            </div>
            <div>
              <label class="mb-1 block text-sm font-medium text-text-secondary"
                >Articles Per Page</label
              >
              <input
                type="number"
                id="page-size"
                value={settings.pageSize || '12'}
                min="1"
                max="50"
                class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none"
              />
            </div>
          </div>
          <div id="settings-message" class="hidden rounded-lg px-4 py-3 text-sm"></div>
          <button
            type="submit"
            class="rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
            >Save Settings</button
          >
        </form>
      </div>

      {/* System Status */}
      <div class="rounded-xl border border-border bg-card p-6">
        <h2 class="mb-4 text-lg font-semibold text-text-primary">System Status</h2>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-text-secondary">Database Status</span>
            <span id="db-status" class="text-warning">Checking...</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-secondary">Node.js Version</span>
            <span class="text-text-primary">--</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-secondary">Environment</span>
            <span class="text-text-primary">Development</span>
          </div>
        </div>
      </div>

      {/* Data Statistics */}
      <div class="rounded-xl border border-border bg-card p-6">
        <h2 class="mb-4 text-lg font-semibold text-text-primary">Data Statistics</h2>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-lg bg-background p-4 text-center">
            <p id="stat-articles" class="text-2xl font-bold text-accent">--</p>
            <p class="text-xs text-text-secondary">Total Articles</p>
          </div>
          <div class="rounded-lg bg-background p-4 text-center">
            <p id="stat-users" class="text-2xl font-bold text-accent">--</p>
            <p class="text-xs text-text-secondary">Total Users</p>
          </div>
          <div class="rounded-lg bg-background p-4 text-center">
            <p id="stat-feeds" class="text-2xl font-bold text-accent">--</p>
            <p class="text-xs text-text-secondary">RSS Feeds</p>
          </div>
          <div class="rounded-lg bg-background p-4 text-center">
            <p id="stat-categories" class="text-2xl font-bold text-accent">--</p>
            <p class="text-xs text-text-secondary">Categories</p>
          </div>
        </div>
      </div>

      {/* Quick Actions */}
      <div class="rounded-xl border border-border bg-card p-6">
        <h2 class="mb-4 text-lg font-semibold text-text-primary">Quick Actions</h2>
        <div class="space-y-2">
          <a
            href="/en/admin/articles/new"
            class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 4v16m8-8H4"></path></svg
            >
            Publish New Article
          </a>
          <a
            href="/en/admin/feeds"
            class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 4v16m8-8H4"></path></svg
            >
            Manage RSS Feeds
          </a>
          <a
            href="/en/"
            target="_blank"
            class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              ></path></svg
            >
            View Frontend
          </a>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  function getEl<T extends HTMLElement = HTMLElement>(id: string): T {
    return document.getElementById(id) as T;
  }

  document.getElementById('settings-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = getEl('settings-message');
    const settings = {
      siteName: getEl<HTMLInputElement>('site-name').value,
      siteDescription: getEl<HTMLTextAreaElement>('site-description').value,
      siteUrl: getEl<HTMLInputElement>('site-url').value,
      siteLang: getEl<HTMLSelectElement>('site-lang').value,
      pageSize: getEl<HTMLInputElement>('page-size').value,
    };
    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ settings }),
      });
      const data = await res.json();
      if (res.ok) {
        msg.textContent = 'Settings saved';
        msg.className = 'rounded-lg bg-success/10 px-4 py-3 text-sm text-success';
      } else {
        msg.textContent = data.error || 'Save failed';
        msg.className = 'rounded-lg bg-error/10 px-4 py-3 text-sm text-error';
      }
      msg.classList.remove('hidden');
      setTimeout(() => msg.classList.add('hidden'), 3000);
    } catch {
      msg.textContent = 'Network error';
      msg.className = 'rounded-lg bg-error/10 px-4 py-3 text-sm text-error';
      msg.classList.remove('hidden');
    }
  });

  async function loadStats() {
    try {
      const [articlesRes, usersRes, feedsRes, categoriesRes] = await Promise.all([
        fetch('/api/articles?limit=1'),
        fetch('/api/users'),
        fetch('/api/feeds'),
        fetch('/api/categories'),
      ]);

      if (articlesRes.ok) {
        const d = await articlesRes.json();
        getEl('stat-articles').textContent = String(d.pagination?.total || 0);
      }
      if (usersRes.ok) {
        const d = await usersRes.json();
        getEl('stat-users').textContent = String(d.pagination?.total || 0);
      }
      if (feedsRes.ok) {
        const d = await feedsRes.json();
        getEl('stat-feeds').textContent = String(d.feeds?.length || 0);
      }
      if (categoriesRes.ok) {
        const d = await categoriesRes.json();
        getEl('stat-categories').textContent = String(d.categories?.length || 0);
      }

      getEl('db-status').textContent = 'Healthy';
      getEl('db-status').className = 'text-success';
    } catch {
      getEl('db-status').textContent = 'Error';
      getEl('db-status').className = 'text-error';
    }
  }

  loadStats();
</script>
