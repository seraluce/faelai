---
// src/pages/en/hot/index.astro
// 功能：热门话题页面（英文） — 按点赞数排序的文章列表
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { db, schema } from '@/lib/db';
import { eq, desc, and } from 'drizzle-orm';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const articles = await db
  .select()
  .from(schema.articles)
  .where(and(eq(schema.articles.status, 'published'), eq(schema.articles.lang, 'en')))
  .orderBy(desc(schema.articles.likeCount))
  .limit(20);
---

<BaseLayout title={t('nav.hot')}>
  <div class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-text-primary">{t('nav.hot')}</h1>
      <p class="mt-2 text-text-secondary">Currently hottest AI articles</p>
    </div>

    <div class="space-y-4">
      {
        articles.map((article, index) => (
          <a
            href={getLocalizedPath('/news/' + article.slug, lang)}
            class="group flex gap-6 rounded-xl border border-border bg-card p-6 transition-all hover:border-border-strong hover:bg-card-hover"
          >
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-lg font-bold text-accent">
              {index + 1}
            </span>
            <div class="flex-1">
              <h2 class="text-lg font-semibold text-text-primary transition-colors group-hover:text-accent">
                {article.title}
              </h2>
              <p class="mt-2 line-clamp-2 text-sm text-text-secondary">{article.excerpt}</p>
              <div class="mt-3 flex items-center gap-4 text-xs text-text-tertiary">
                {article.sourceName && <span>{article.sourceName}</span>}
                {article.readingTime && <span>{article.readingTime} min read</span>}
                <span>{(article.likeCount ?? 0).toLocaleString()} likes</span>
                <span>{(article.viewCount ?? 0).toLocaleString()} views</span>
              </div>
            </div>
            {article.coverImage && (
              <div class="hidden h-24 w-24 shrink-0 overflow-hidden rounded-lg sm:block">
                <img
                  src={article.coverImage}
                  alt={article.title}
                  class="h-full w-full object-cover"
                />
              </div>
            )}
          </a>
        ))
      }
    </div>

    {
      articles.length === 0 && (
        <div class="py-12 text-center">
          <p class="text-text-tertiary">{t('common.noData')}</p>
        </div>
      )
    }
  </div>
</BaseLayout>
