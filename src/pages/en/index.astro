const trendingArticles = [
  {
    title: 'AI Agent Automation Workflow Guide',
    slug: 'ai-agent-automation-workflow',
    viewCount: 5600,
  },
  { title: 'RAG Technology Best Practices', slug: 'rag-best-practices', viewCount: 4200 },
  { title: 'LLM Fine-Tuning Tutorial', slug: 'llm-fine-tuning-tutorial', viewCount: 3800 },
  { title: 'Diffusion Model Explained', slug: 'diffusion-model-explained', viewCount: 3200 },
  {
    title: 'AI Coding Assistant Comparison',
    slug: 'ai-coding-assistant-comparison',
    viewCount: 2900,
  },
];

const hotTopics = [
  { name: 'GPT-5', count: 128 },
  { name: 'AI Agent', count: 96 },
  { name: 'Claude 4', count: 87 },
  { name: 'Open Source', count: 75 },
  { name: 'AI Safety', count: 68 },
  { name: 'Multimodal', count: 54 },
  { name: 'AI Coding', count: 49 },
  { name: 'Robotics', count: 42 },
];

const categories = [
  { name: 'AI Companies', slug: 'ai-companies', icon: '🏢', color: '#0070f3' },
  { name: 'Research', slug: 'research', icon: '📚', color: '#7928ca' },
  { name: 'AI Products', slug: 'ai-products', icon: '🚀', color: '#ff0080' },
  { name: 'Industry', slug: 'industry', icon: '📊', color: '#f5a623' },
  { name: 'Open Source', slug: 'open-source', icon: '💻', color: '#50e3c2' },
  { name: 'AI Ethics', slug: 'ai-ethics', icon: '⚖️', color: '#ee0000' },
