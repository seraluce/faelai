    coverImage: 'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=800&q=80',
    sourceName: 'MIT Tech Review',
    publishedAt: new Date(Date.now() - 6 * 60 * 60 * 1000),
    readingTime: 6,
  },
];

