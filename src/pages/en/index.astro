---
// src/pages/en/index.astro
// 功能：首页（英文） — 新闻滚动条、精选文章、最新资讯、热门排行、热门话题、分类导航、订阅表单
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsCard from '@/components/news/NewsCard.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { db, schema } from '@/lib/db';
import { eq, desc, and, sql } from 'drizzle-orm';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const langFilter = eq(schema.articles.lang, 'en');
const publishedFilter = eq(schema.articles.status, 'published');

// Featured articles (3)
const featuredArticles = await db
  .select()
  .from(schema.articles)
  .where(and(publishedFilter, langFilter, eq(schema.articles.isFeatured, true)))
  .orderBy(desc(schema.articles.publishedAt))
  .limit(3);

const featuredSlugs = new Set(featuredArticles.map((a) => a.slug));
const needCount = 3 - featuredArticles.length;
const fallbackFeatured =
  needCount > 0
    ? await db
        .select()
        .from(schema.articles)
        .where(and(publishedFilter, langFilter))
        .orderBy(desc(schema.articles.publishedAt))
        .limit(needCount)
    : [];
const allFeatured = [
  ...featuredArticles,
  ...fallbackFeatured.filter((a) => !featuredSlugs.has(a.slug)),
].slice(0, 3);

// Latest articles (6)
const latestArticles = await db
  .select()
  .from(schema.articles)
  .where(and(publishedFilter, langFilter))
  .orderBy(desc(schema.articles.publishedAt))
  .limit(6);

// Trending articles by view count (5)
const trendingArticles = await db
  .select({
    title: schema.articles.title,
    slug: schema.articles.slug,
    viewCount: schema.articles.viewCount,
  })
  .from(schema.articles)
  .where(and(publishedFilter, langFilter))
  .orderBy(desc(schema.articles.viewCount))
  .limit(5);

// Hot topics (tags + article count, 8)
const hotTopics = await db
  .select({
    name: schema.tags.name,
    slug: schema.tags.slug,
    count: sql<number>`count(${schema.articleTags.articleId})`.as('count'),
  })
  .from(schema.tags)
  .innerJoin(schema.articleTags, eq(schema.tags.id, schema.articleTags.tagId))
  .innerJoin(schema.articles, eq(schema.articleTags.articleId, schema.articles.id))
  .where(and(publishedFilter, langFilter))
  .groupBy(schema.tags.id)
  .orderBy(desc(sql`count(${schema.articleTags.articleId})`))
  .limit(8);

// Categories
const categories = await db.select().from(schema.categories).orderBy(schema.categories.sortOrder);
---

<BaseLayout title={t('home.hero.title')} description={t('home.hero.subtitle')}>
  {/* Breaking News Ticker */}
  <div class="border-b border-border bg-background-secondary">
    <div class="mx-auto max-w-7xl overflow-hidden">
      <div class="flex items-center">
        <span class="shrink-0 bg-accent px-3 py-2 text-xs font-semibold text-white">BREAKING</span>
        <div class="relative flex-1 overflow-hidden">
          <div class="ticker-animate flex whitespace-nowrap py-2">
            {
              latestArticles
                .slice(0, 4)
                .map((article) => (
                  <span class="mx-8 text-sm text-text-secondary">{article.title}</span>
                ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Hero Section */}
  <section class="mx-auto max-w-7xl px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-text-primary md:text-4xl">
        {t('home.hero.title')}
      </h1>
      <p class="mt-2 text-lg text-text-secondary">
        {t('home.hero.subtitle')}
      </p>
    </div>

    {/* Hero Grid */}
    {
      allFeatured.length > 0 && (
        <div class="grid gap-6 md:grid-cols-2">
          {/* Main Featured */}
          <div class="md:row-span-2">
            <NewsCard {...allFeatured[0]} featured={true} lang={lang} />
          </div>
          {/* Side Featured */}
          {allFeatured[1] && <NewsCard {...allFeatured[1]} lang={lang} />}
          {allFeatured[2] && <NewsCard {...allFeatured[2]} lang={lang} />}
        </div>
      )
    }
  </section>

  {/* Main Content */}
  <section class="mx-auto max-w-7xl px-4 py-12">
    <div class="grid gap-8 lg:grid-cols-3">
      {/* Latest News */}
      <div class="lg:col-span-2">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-xl font-semibold text-text-primary">{t('home.latest')}</h2>
          <a href={getLocalizedPath('/news', lang)} class="text-sm text-accent hover:underline">
            {t('home.viewAll')}
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          {latestArticles.map((article) => <NewsCard {...article} lang={lang} />)}
        </div>
      </div>

      {/* Sidebar */}
      <div class="space-y-8">
        {/* Trending */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 text-lg font-semibold text-text-primary">{t('home.trending')}</h3>
          <ul class="space-y-4">
            {
              trendingArticles.map((article, index) => (
                <li>
                  <a
                    href={getLocalizedPath('/news/' + article.slug, lang)}
                    class="group flex gap-3"
                  >
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-muted text-sm font-semibold text-text-tertiary">
                      {index + 1}
                    </span>
                    <div>
                      <p class="text-sm font-medium text-text-primary transition-colors group-hover:text-accent">
                        {article.title}
                      </p>
                      <p class="text-xs text-text-tertiary">
                        {article.viewCount?.toLocaleString()} views
                      </p>
                    </div>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        {/* Hot Topics */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-4 text-lg font-semibold text-text-primary">{t('home.hot')}</h3>
          <div class="flex flex-wrap gap-2">
            {
              hotTopics.map((topic) => (
                <a
                  href={getLocalizedPath('/tag/' + topic.slug, lang)}
                  class="rounded-full border border-border px-3 py-1.5 text-sm text-text-secondary transition-colors hover:border-accent hover:text-accent"
                >
                  {topic.name}
                  <span class="ml-1 text-xs text-text-tertiary">({topic.count})</span>
                </a>
              ))
            }
          </div>
        </div>

        {/* Newsletter */}
        <div class="rounded-xl border border-border bg-card p-6">
          <h3 class="mb-2 text-lg font-semibold text-text-primary">Subscribe to Newsletter</h3>
          <p class="mb-4 text-sm text-text-secondary">
            Weekly curated AI news, delivered to your inbox
          </p>
          <form class="flex gap-2">
            <input
              type="email"
              placeholder="your@email.com"
              class="flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-text-primary placeholder-text-tertiary focus:border-accent focus:outline-none"
            />
            <button
              type="submit"
              class="shrink-0 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  {/* Categories Section */}
  <section class="border-t border-border bg-background-secondary py-12">
    <div class="mx-auto max-w-7xl px-4">
      <h2 class="mb-8 text-xl font-semibold text-text-primary">Explore Categories</h2>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-6">
        {
          categories.map((category) => (
            <a
              href={getLocalizedPath('/category/' + category.slug, lang)}
              class="group flex flex-col items-center rounded-xl border border-border bg-card p-6 transition-all hover:border-border-strong hover:bg-card-hover"
            >
              {category.icon && <span class="mb-3 text-3xl" set:html={category.icon} />}
              <span class="text-sm font-medium text-text-primary">
                {lang === 'en' ? category.nameEn || category.name : category.name}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .ticker-animate {
    animation: ticker 30s linear infinite;
  }

  @keyframes ticker {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
