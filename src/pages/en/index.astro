    publishedAt: new Date(Date.now() - 12 * 60 * 60 * 1000),
    readingTime: 6,
    viewCount: 2100,
  },
  {
    title: 'Hugging Face Releases Transformers v5',
    slug: 'huggingface-transformers-v5-release',
