---
// src/pages/en/index.astro
// 功能：首页（英文） — 精选文章、最新资讯、热门排行、热门话题、分类导航、订阅表单
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsCard from '@/components/news/NewsCard.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { db, schema } from '@/lib/db';
import { eq, desc, and, sql } from 'drizzle-orm';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const langFilter = eq(schema.articles.lang, 'en');
const publishedFilter = eq(schema.articles.status, 'published');

// Featured articles (3)
const featuredArticles = await db
  .select()
  .from(schema.articles)
  .where(and(publishedFilter, langFilter, eq(schema.articles.isFeatured, true)))
  .orderBy(desc(schema.articles.publishedAt))
  .limit(3);

const featuredSlugs = new Set(featuredArticles.map((a) => a.slug));
const needCount = 3 - featuredArticles.length;
const fallbackFeatured =
  needCount > 0
    ? await db
        .select()
        .from(schema.articles)
        .where(and(publishedFilter, langFilter))
        .orderBy(desc(schema.articles.publishedAt))
        .limit(needCount)
    : [];
const allFeatured = [
  ...featuredArticles,
  ...fallbackFeatured.filter((a) => !featuredSlugs.has(a.slug)),
].slice(0, 3);

// Latest articles (6)
const latestArticles = await db
  .select()
  .from(schema.articles)
  .where(and(publishedFilter, langFilter))
  .orderBy(desc(schema.articles.publishedAt))
  .limit(6);

// Trending articles by view count (5)
const trendingArticles = await db
  .select({
    title: schema.articles.title,
    slug: schema.articles.slug,
    viewCount: schema.articles.viewCount,
  })
  .from(schema.articles)
  .where(and(publishedFilter, langFilter))
  .orderBy(desc(schema.articles.viewCount))
  .limit(5);

// Hot topics (tags + article count, 8)
const hotTopics = await db
  .select({
    name: schema.tags.name,
    slug: schema.tags.slug,
    count: sql<number>`count(${schema.articleTags.articleId})`.as('count'),
  })
  .from(schema.tags)
  .innerJoin(schema.articleTags, eq(schema.tags.id, schema.articleTags.tagId))
  .innerJoin(schema.articles, eq(schema.articleTags.articleId, schema.articles.id))
  .where(and(publishedFilter, langFilter))
  .groupBy(schema.tags.id)
  .orderBy(desc(sql`count(${schema.articleTags.articleId})`))
  .limit(8);

// Categories
const categories = await db.select().from(schema.categories).orderBy(schema.categories.sortOrder);
---

<BaseLayout title={t('home.hero.title')} description={t('home.hero.subtitle')}>
  {/* Hero Section */}
  <section class="mx-auto max-w-7xl px-4 pt-16 pb-12">
    <div class="mb-10 max-w-2xl">
      <h1
        class="text-4xl font-semibold text-text-primary tracking-[-0.04em] md:text-5xl"
        style="line-height: 1.1"
      >
        {t('home.hero.title')}
      </h1>
      <p class="mt-4 text-lg text-text-secondary leading-relaxed">
        {t('home.hero.subtitle')}
      </p>
    </div>

    {/* Hero Grid */}
    {
      allFeatured.length > 0 && (
        <div class="grid gap-6 md:grid-cols-2">
          {/* Main Featured */}
          <div class="md:row-span-2">
            <NewsCard {...allFeatured[0]} featured={true} lang={lang} />
          </div>
          {/* Side Featured */}
          {allFeatured[1] && <NewsCard {...allFeatured[1]} lang={lang} />}
          {allFeatured[2] && <NewsCard {...allFeatured[2]} lang={lang} />}
        </div>
      )
    }
  </section>

  {/* Divider */}
  <div class="mx-auto max-w-7xl px-4">
    <div class="border-t border-border"></div>
  </div>

  {/* Main Content */}
  <section class="mx-auto max-w-7xl px-4 py-12">
    <div class="grid gap-8 lg:grid-cols-3">
      {/* Latest News */}
      <div class="lg:col-span-2">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-xl font-semibold text-text-primary tracking-[-0.02em]">
            {t('home.latest')}
          </h2>
          <a
            href={getLocalizedPath('/news', lang)}
            class="text-sm font-medium text-accent transition-colors duration-150 hover:text-accent-hover"
          >
            {t('home.viewAll')}
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          {latestArticles.map((article) => <NewsCard {...article} lang={lang} />)}
        </div>
      </div>

      {/* Sidebar */}
      <div class="space-y-8">
        {/* Trending */}
        <div class="pb-4">
          <h3
            class="mb-3 border-b border-border pb-3 text-base font-semibold text-text-primary tracking-[-0.02em]"
          >
            {t('home.trending')}
          </h3>
          <ul class="space-y-0">
            {
              trendingArticles.map((article, index) => (
                <li>
                  <a
                    href={getLocalizedPath('/news/' + article.slug, lang)}
                    class:list={[
                      'group flex items-start gap-3 py-3',
                      index > 0 && 'border-t border-border',
                    ]}
                  >
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center text-sm font-semibold text-text-disabled">
                      {index + 1}
                    </span>
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-text-primary leading-snug transition-colors duration-150 group-hover:text-accent">
                        {article.title}
                      </p>
                      <p class="mt-1 text-xs text-text-disabled">
                        {article.viewCount?.toLocaleString()} views
                      </p>
                    </div>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        {/* Hot Topics */}
        <div class="pb-4">
          <h3
            class="mb-3 border-b border-border pb-3 text-base font-semibold text-text-primary tracking-[-0.02em]"
          >
            {t('home.hot')}
          </h3>
          <div class="flex flex-wrap gap-2">
            {
              hotTopics.map((topic) => (
                <a
                  href={getLocalizedPath('/tag/' + topic.slug, lang)}
                  class="rounded-[6px] px-3 py-1.5 text-sm font-medium text-text-secondary transition-all duration-150 hover:text-text-primary"
                >
                  {topic.name}
                  <span class="ml-1 text-text-disabled">{topic.count}</span>
                </a>
              ))
            }
          </div>
        </div>

        {/* Newsletter */}
        <div class="pb-4">
          <h3
            class="mb-1 border-b border-border pb-3 text-base font-semibold text-text-primary tracking-[-0.02em]"
          >
            Subscribe to Newsletter
          </h3>
          <p class="mb-4 text-sm text-text-secondary">
            Weekly curated AI news, delivered to your inbox
          </p>
          <form class="flex gap-2">
            <input
              type="email"
              placeholder="your@email.com"
              class="min-w-0 flex-1 rounded-[6px] border border-border bg-background px-3 py-2 text-sm text-text-primary placeholder-text-disabled transition-all duration-150 focus:border-accent focus:outline-none"
            />
            <button
              type="submit"
              class="shrink-0 rounded-[6px] bg-text-primary px-4 py-2 text-sm font-medium text-background transition-all duration-150 hover:bg-text-secondary"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  {/* Categories Section */}
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4">
      <h2
        class="mb-8 border-b border-border pb-4 text-xl font-semibold text-text-primary tracking-[-0.02em]"
      >
        Explore Categories
      </h2>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-6">
        {
          categories.map((category) => (
            <a
              href={getLocalizedPath('/category/' + category.slug, lang)}
              class="group flex flex-col items-center rounded-[12px] px-4 py-4 text-center transition-all duration-150 hover:bg-background-secondary"
            >
              {category.icon && <span class="mb-3 text-3xl" set:html={category.icon} />}
              <span class="text-sm font-medium text-text-primary">
                {lang === 'en' ? category.nameEn || category.name : category.name}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
