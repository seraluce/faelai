---
// src/pages/en/news/index.astro
// 功能：新闻列表页面（英文） — 分类筛选标签、文章网格、分页
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsCard from '@/components/news/NewsCard.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const articles = [
  {
    title: 'OpenAI Releases GPT-5 with Enhanced Reasoning Capabilities',
    slug: 'openai-releases-gpt-5-with-reasoning-capabilities',
    excerpt:
      'OpenAI has officially released GPT-5, achieving significant breakthroughs in mathematical reasoning, code generation, and multilingual understanding.',
    coverImage: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&q=80',
    sourceName: 'OpenAI Blog',
    publishedAt: new Date(Date.now() - 2 * 60 * 60 * 1000),
    readingTime: 5,
    viewCount: 3200,
  },
  {
    title: 'Anthropic Publishes Claude 4 Safety Research Report',
    slug: 'anthropic-claude-4-safety-research',
    excerpt:
      'Anthropic has released an in-depth research report on Claude 4 safety, showcasing the latest progress in AI safety alignment.',
    coverImage: 'https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=800&q=80',
    sourceName: 'Anthropic',
    publishedAt: new Date(Date.now() - 4 * 60 * 60 * 1000),
    readingTime: 8,
    viewCount: 2100,
  },
  {
    title: 'Google DeepMind Achieves New Breakthrough in Protein Folding',
    slug: 'google-deepmind-protein-folding-breakthrough',
    excerpt:
      "DeepMind's AlphaFold 3 has achieved new milestone results in protein structure prediction.",
    coverImage: 'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=800&q=80',
    sourceName: 'MIT Tech Review',
    publishedAt: new Date(Date.now() - 6 * 60 * 60 * 1000),
    readingTime: 6,
    viewCount: 1800,
  },
  {
    title: 'Meta Releases Llama 4 Open Source AI Model',
    slug: 'meta-llama-4-open-source-ai-model',
    excerpt:
      'Meta has released the latest Llama 4 open source large language model, performing excellently in multiple benchmarks.',
    coverImage: 'https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=800&q=80',
    sourceName: 'TechCrunch',
    publishedAt: new Date(Date.now() - 8 * 60 * 60 * 1000),
    readingTime: 4,
    viewCount: 1250,
  },
  {
    title: 'xAI Grok 3 Multimodal Update Released',
    slug: 'xai-grok-3-multimodal-update',
    excerpt:
      'xAI announces major update for Grok 3, supporting image understanding and real-time information retrieval.',
    coverImage: 'https://images.unsplash.com/photo-1676299081847-824916de030a?w=800&q=80',
    sourceName: 'xAI',
    publishedAt: new Date(Date.now() - 10 * 60 * 60 * 1000),
    readingTime: 3,
    viewCount: 890,
  },
  {
    title: 'China Releases New AI Regulation Policy',
    slug: 'china-ai-regulation-new-policy-2026',
    excerpt:
      'Chinese authorities have released the latest regulatory policy framework for artificial intelligence technology.',
    sourceName: '机器之心',
    publishedAt: new Date(Date.now() - 12 * 60 * 60 * 1000),
    readingTime: 6,
    viewCount: 2100,
  },
  {
    title: 'Hugging Face Releases Transformers v5',
    slug: 'huggingface-transformers-v5-release',
    excerpt:
      'Hugging Face introduces a major version update of the Transformers library, supporting more model architectures.',
    coverImage: 'https://images.unsplash.com/photo-1555949963-aa79dcee981c?w=800&q=80',
    sourceName: 'Hugging Face',
    publishedAt: new Date(Date.now() - 14 * 60 * 60 * 1000),
    readingTime: 5,
    viewCount: 670,
  },
  {
    title: 'NVIDIA Releases Next-Gen AI Training GPU',
    slug: 'nvidia-gpu-ai-training-optimization',
    excerpt: 'NVIDIA introduces a new GPU architecture optimized for AI training.',
    coverImage: 'https://images.unsplash.com/photo-1591799264318-7e6ef8ddb7ea?w=800&q=80',
    sourceName: 'NVIDIA Blog',
    publishedAt: new Date(Date.now() - 16 * 60 * 60 * 1000),
    readingTime: 4,
    viewCount: 1580,
  },
];

const categories = [
  { name: 'All', slug: 'all' },
  { name: 'AI Companies', slug: 'ai-companies' },
  { name: 'Research', slug: 'research' },
  { name: 'AI Products', slug: 'ai-products' },
  { name: 'Industry', slug: 'industry' },
  { name: 'Open Source', slug: 'open-source' },
];
---

<BaseLayout title={t('nav.news')} description={t('home.hero.subtitle')}>
  <div class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-text-primary">{t('nav.news')}</h1>
      <p class="mt-2 text-text-secondary">Browse all AI news and insights</p>
    </div>

    <div class="mb-8 flex flex-wrap gap-2">
      {
        categories.map((cat, i) => (
          <button
            class={`rounded-full px-4 py-2 text-sm font-medium transition-colors ${
              i === 0
                ? 'bg-accent text-white'
                : 'border border-border bg-background text-text-secondary hover:border-accent hover:text-accent'
            }`}
            data-category={cat.slug}
          >
            {cat.name}
          </button>
        ))
      }
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {articles.map((article) => <NewsCard {...article} lang={lang} />)}
    </div>

    <div class="mt-12 flex justify-center">
      <div class="flex items-center gap-2">
        <button
          class="rounded-lg border border-border bg-background px-4 py-2 text-sm text-text-tertiary"
          disabled
        >
          {t('common.prev')}
        </button>
        <span class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white">1</span>
        <button
          class="rounded-lg border border-border bg-background px-4 py-2 text-sm text-text-secondary hover:bg-background-hover"
        >
          2
        </button>
        <button
          class="rounded-lg border border-border bg-background px-4 py-2 text-sm text-text-secondary hover:bg-background-hover"
        >
          3
        </button>
        <span class="px-2 text-text-tertiary">...</span>
        <button
          class="rounded-lg border border-border bg-background px-4 py-2 text-sm text-text-secondary hover:bg-background-hover"
        >
          {t('common.next')}
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
