---
// src/pages/en/reset-password/index.astro
// 功能：密码重置页面（英文） — 无 token 时显示申请表单，有 token 时显示设置新密码表单
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

if (Astro.locals.user) {
  return Astro.redirect(getLocalizedPath('/', lang));
}

const token = Astro.url.searchParams.get('token');
---

<BaseLayout title={t('auth.resetPassword.title')}>
  <div
    class="mx-auto flex min-h-[calc(100vh-8rem)] max-w-md items-center justify-center px-4 py-12"
  >
    <div class="w-full">
      {
        token ? (
          <div id="set-password-view">
            <div class="mb-8 text-center">
              <h1 class="text-2xl font-bold text-text-primary">Set New Password</h1>
              <p class="mt-2 text-sm text-text-secondary">Enter your new password</p>
            </div>

            <form id="set-password-form" class="space-y-4">
              <input type="hidden" name="token" value={token} />
              <div>
                <label for="password" class="mb-1 block text-sm font-medium text-text-secondary">
                  New Password
                </label>
                <input
                  type="password"
                  id="password"
                  name="password"
                  required
                  minlength={8}
                  class="w-full rounded-lg border border-border bg-background px-4 py-3 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
                  placeholder="At least 8 characters"
                />
              </div>
              <div>
                <label
                  for="confirm-password"
                  class="mb-1 block text-sm font-medium text-text-secondary"
                >
                  Confirm New Password
                </label>
                <input
                  type="password"
                  id="confirm-password"
                  name="confirm-password"
                  required
                  minlength={8}
                  class="w-full rounded-lg border border-border bg-background px-4 py-3 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
                  placeholder="Re-enter new password"
                />
              </div>

              <div
                id="error-message"
                class="hidden rounded-lg bg-error/10 px-4 py-3 text-sm text-error"
              ></div>

              <div
                id="success-message"
                class="hidden rounded-lg bg-success/10 px-4 py-3 text-sm text-success"
              ></div>

              <button
                type="submit"
                class="w-full rounded-lg bg-accent py-3 font-medium text-white transition-colors hover:bg-accent-hover"
              >
                Reset Password
              </button>
            </form>
          </div>
        ) : (
          <div id="request-reset-view">
            <div class="mb-8 text-center">
              <h1 class="text-2xl font-bold text-text-primary">Reset Password</h1>
              <p class="mt-2 text-sm text-text-secondary">
                Enter your email address and we'll send you a reset link
              </p>
            </div>

            <form id="reset-password-form" class="space-y-4">
              <div>
                <label for="email" class="mb-1 block text-sm font-medium text-text-secondary">
                  {t('auth.login.email')}
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full rounded-lg border border-border bg-background px-4 py-3 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
                  placeholder="your@email.com"
                />
              </div>

              <div
                id="error-message"
                class="hidden rounded-lg bg-error/10 px-4 py-3 text-sm text-error"
              ></div>

              <div
                id="success-message"
                class="hidden rounded-lg bg-success/10 px-4 py-3 text-sm text-success"
              ></div>

              <button
                type="submit"
                class="w-full rounded-lg bg-accent py-3 font-medium text-white transition-colors hover:bg-accent-hover"
              >
                {t('auth.resetPassword.submit')}
              </button>
            </form>

            <p class="mt-6 text-center text-sm text-text-secondary">
              {t('auth.login.noAccount')}
              <a
                href={getLocalizedPath('/register', lang)}
                class="font-medium text-accent hover:underline"
              >
                {t('auth.register.title')}
              </a>
            </p>
          </div>
        )
      }
    </div>
  </div>
</BaseLayout>

<script>
  const errorDiv = document.getElementById('error-message')!;
  const successDiv = document.getElementById('success-message')!;

  function showError(msg: string) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
  }

  function showSuccess(msg: string) {
    successDiv.textContent = msg;
    successDiv.classList.remove('hidden');
  }

  function clearMessages() {
    errorDiv.classList.add('hidden');
    successDiv.classList.add('hidden');
  }

  const setPasswordForm = document.getElementById('set-password-form') as HTMLFormElement | null;
  if (setPasswordForm) {
    setPasswordForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearMessages();

      const formData = new FormData(setPasswordForm);
      const token = formData.get('token') as string;
      const password = formData.get('password') as string;
      const confirmPassword = formData.get('confirm-password') as string;

      if (password !== confirmPassword) {
        showError('Passwords do not match');
        return;
      }

      if (password.length < 8) {
        showError('Password must be at least 8 characters');
        return;
      }

      try {
        const res = await fetch('/api/auth/confirm-reset', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, password }),
        });

        const data = await res.json();

        if (!res.ok) {
          showError(data.error);
          return;
        }

        showSuccess('Password has been reset. Redirecting to login...');
        setTimeout(() => {
          window.location.href = '/en/login';
        }, 2000);
      } catch {
        showError('Network error, please try again later');
      }
    });
  }

  const resetPasswordForm = document.getElementById(
    'reset-password-form'
  ) as HTMLFormElement | null;
  if (resetPasswordForm) {
    resetPasswordForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearMessages();

      const formData = new FormData(resetPasswordForm);
      const email = formData.get('email') as string;

      try {
        const res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const data = await res.json();

        if (!res.ok) {
          showError(data.error);
          return;
        }

        showSuccess(data.message);
        resetPasswordForm.reset();
      } catch {
        showError('Network error, please try again later');
      }
    });
  }
</script>
