---
// src/pages/en/search/index.astro
// 功能：搜索页面（英文） — 搜索输入框、防抖搜索、调用 API 展示结果
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('search.title')}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-text-primary">{t('search.title')}</h1>
      <p class="mt-2 text-text-secondary">Search AI news, articles and topics</p>
    </div>

    <div class="mb-8">
      <form id="search-form" class="relative">
        <svg
          class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-text-tertiary"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder={t('search.placeholder')}
          class="w-full rounded-xl border border-border bg-background py-4 pl-12 pr-4 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
          autofocus
        />
      </form>
    </div>

    <div id="search-results">
      <div class="py-12 text-center">
        <p class="text-text-tertiary">Type to start searching</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results')!;

  let debounceTimer: ReturnType<typeof setTimeout>;

  function renderResults(articles: any[]) {
    if (articles.length === 0) {
      results.innerHTML =
        '<div class="py-12 text-center"><p class="text-text-tertiary">No results found</p></div>';
      return;
    }

    const items = articles
      .map(
        (a) => `
        <a href="/en/news/${a.slug}" class="block rounded-xl border border-border bg-card p-6 transition-all hover:border-border-strong hover:bg-card-hover">
          <h3 class="font-semibold text-text-primary">${a.title}</h3>
          ${a.excerpt ? `<p class="mt-2 text-sm text-text-secondary">${a.excerpt.length > 150 ? a.excerpt.slice(0, 150) + '...' : a.excerpt}</p>` : ''}
          <div class="mt-3 flex items-center gap-4 text-xs text-text-tertiary">
            ${a.sourceName ? `<span>${a.sourceName}</span>` : ''}
            ${a.readingTime ? `<span>${a.readingTime} min read</span>` : ''}
          </div>
        </a>`
      )
      .join('');

    results.innerHTML = `
      <div class="space-y-4">
        <p class="text-sm text-text-tertiary">Found ${articles.length} results</p>
        ${items}
      </div>
    `;
  }

  input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
      const query = input.value.trim();
      if (!query) {
        results.innerHTML =
          '<div class="py-12 text-center"><p class="text-text-tertiary">Type to start searching</p></div>';
        return;
      }

      results.innerHTML =
        '<div class="py-12 text-center"><p class="text-text-tertiary">Searching...</p></div>';

      try {
        const res = await fetch(
          `/api/articles?search=${encodeURIComponent(query)}&status=published&lang=en&limit=20`
        );
        const data = await res.json();
        renderResults(data.articles || []);
      } catch {
        results.innerHTML =
          '<div class="py-12 text-center"><p class="text-text-tertiary">Search error, please try again</p></div>';
      }
    }, 300);
  });
</script>
