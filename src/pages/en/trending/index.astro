---
// src/pages/en/trending/index.astro
// 功能：热门排行页面（英文） — 按浏览量排序的文章列表
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsCard from '@/components/news/NewsCard.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const trendingArticles = [
  {
    title: 'AI Agent Automation Workflow Guide',
    slug: 'ai-agent-automation-workflow',
    excerpt:
      'Deep dive into AI Agent design patterns and best practices for building efficient automation workflows.',
    coverImage: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&q=80',
    sourceName: 'FaelAI',
    publishedAt: new Date(Date.now() - 24 * 60 * 60 * 1000),
    readingTime: 12,
    viewCount: 5600,
  },
  {
    title: 'RAG Technology Best Practices: From Beginner to Expert',
    slug: 'rag-best-practices',
    excerpt: 'Comprehensive guide to RAG implementation strategies and optimization techniques.',
    coverImage: 'https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=800&q=80',
    sourceName: 'FaelAI',
    publishedAt: new Date(Date.now() - 48 * 60 * 60 * 1000),
    readingTime: 15,
    viewCount: 4200,
  },
  {
    title: 'LLM Fine-Tuning Tutorial',
    slug: 'llm-fine-tuning-tutorial',
    excerpt:
      'Step-by-step guide to fine-tuning large language models for specific business scenarios.',
    coverImage: 'https://images.unsplash.com/photo-1555949963-aa79dcee981c?w=800&q=80',
    sourceName: 'FaelAI',
    publishedAt: new Date(Date.now() - 72 * 60 * 60 * 1000),
    readingTime: 10,
    viewCount: 3800,
  },
  {
    title: 'Diffusion Model Explained',
    slug: 'diffusion-model-explained',
    excerpt:
      'Deep understanding of the mathematical principles and implementation details of diffusion models.',
    coverImage: 'https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=800&q=80',
    sourceName: 'FaelAI',
    publishedAt: new Date(Date.now() - 96 * 60 * 60 * 1000),
    readingTime: 8,
    viewCount: 3200,
  },
  {
    title: 'AI Coding Assistant Comparison',
    slug: 'ai-coding-assistant-comparison',
    excerpt: 'Comparing GitHub Copilot, Cursor, Codeium and other leading AI coding assistants.',
    coverImage: 'https://images.unsplash.com/photo-1591799264318-7e6ef8ddb7ea?w=800&q=80',
    sourceName: 'FaelAI',
    publishedAt: new Date(Date.now() - 120 * 60 * 60 * 1000),
    readingTime: 7,
    viewCount: 2900,
  },
];
---

<BaseLayout title={t('nav.trending')}>
  <div class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-text-primary">{t('nav.trending')}</h1>
      <p class="mt-2 text-text-secondary">Most popular AI articles</p>
    </div>

    <div class="space-y-4">
      {
        trendingArticles.map((article, index) => (
          <a
            href={getLocalizedPath('/news/' + article.slug, lang)}
            class="group flex gap-6 rounded-xl border border-border bg-card p-6 transition-all hover:border-border-strong hover:bg-card-hover"
          >
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-lg font-bold text-accent">
              {index + 1}
            </span>
            <div class="flex-1">
              <h2 class="text-lg font-semibold text-text-primary transition-colors group-hover:text-accent">
                {article.title}
              </h2>
              <p class="mt-2 line-clamp-2 text-sm text-text-secondary">{article.excerpt}</p>
              <div class="mt-3 flex items-center gap-4 text-xs text-text-tertiary">
                <span>{article.sourceName}</span>
                <span>{article.readingTime} min read</span>
                <span>{article.viewCount.toLocaleString()} views</span>
              </div>
            </div>
            {article.coverImage && (
              <div class="hidden h-24 w-24 shrink-0 overflow-hidden rounded-lg sm:block">
                <img
                  src={article.coverImage}
                  alt={article.title}
                  class="h-full w-full object-cover"
                />
              </div>
            )}
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
