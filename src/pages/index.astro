  { title: 'RAG 技术最佳实践', slug: 'rag-best-practices', viewCount: 4200 },
  { title: '大模型微调入门教程', slug: 'llm-fine-tuning-tutorial', viewCount: 3800 },
  { title: 'Diffusion 模型原理解析', slug: 'diffusion-model-explained', viewCount: 3200 },
  { title: 'AI 编程助手对比评测', slug: 'ai-coding-assistant-comparison', viewCount: 2900 },
];

const hotTopics = [
  { name: 'GPT-5', count: 128 },
  { name: 'AI Agent', count: 96 },
  { name: 'Claude 4', count: 87 },
  { name: '开源模型', count: 75 },
  { name: 'AI 安全', count: 68 },
  { name: '多模态', count: 54 },
  { name: 'AI 编程', count: 49 },
  { name: '机器人', count: 42 },
];

const categories = [
  { name: 'AI 公司', slug: 'ai-companies', icon: '🏢', color: '#0070f3' },
  { name: '学术研究', slug: 'research', icon: '📚', color: '#7928ca' },
  { name: 'AI 产品', slug: 'ai-products', icon: '🚀', color: '#ff0080' },
  { name: '行业动态', slug: 'industry', icon: '📊', color: '#f5a623' },
  { name: '开源项目', slug: 'open-source', icon: '💻', color: '#50e3c2' },
  { name: 'AI 伦理', slug: 'ai-ethics', icon: '⚖️', color: '#ee0000' },
