---
// src/pages/news/[slug].astro
// 功能：文章详情页面（中文） -- 从数据库查询真实文章数据、浏览量、相关文章、标签
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { db, schema } from '@/lib/db';
import { eq, and, desc } from 'drizzle-orm';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const articles = await db
  .select()
  .from(schema.articles)
  .where(eq(schema.articles.slug, slug))
  .limit(1);

if (articles.length === 0) return Astro.redirect('/404');

const article = articles[0];

// 浏览量 +1
await db
  .update(schema.articles)
  .set({ viewCount: (article.viewCount || 0) + 1 })
  .where(eq(schema.articles.id, article.id));

// 分类信息
const category = article.categoryId
  ? await db
      .select()
      .from(schema.categories)
      .where(eq(schema.categories.id, article.categoryId))
      .limit(1)
      .then((rows) => rows[0] || null)
  : null;

// 标签
const articleTags = await db
  .select({ tagId: schema.articleTags.tagId, name: schema.tags.name, slug: schema.tags.slug })
  .from(schema.articleTags)
  .innerJoin(schema.tags, eq(schema.articleTags.tagId, schema.tags.id))
  .where(eq(schema.articleTags.articleId, article.id));

// 相关文章（同分类，排除当前）
const relatedArticles = article.categoryId
  ? await db
      .select()
      .from(schema.articles)
      .where(
        and(
          eq(schema.articles.status, 'published'),
          eq(schema.articles.categoryId, article.categoryId)
        )
      )
      .orderBy(desc(schema.articles.publishedAt))
      .limit(4)
      .then((rows) => rows.filter((a) => a.id !== article.id).slice(0, 3))
  : [];
---

<BaseLayout
  title={article.title}
  description={article.excerpt || article.description || ''}
  image={article.coverImage || undefined}
  type="article"
  publishedAt={article.publishedAt?.toISOString()}
>
  <article class="mx-auto max-w-4xl px-4 py-8">
    {/* 面包屑 */}
    <nav class="mb-6 text-sm text-text-tertiary">
      <a href={getLocalizedPath('/', lang)} class="hover:text-accent">首页</a>
      <span class="mx-2">/</span>
      <a href={getLocalizedPath('/news', lang)} class="hover:text-accent">资讯</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">{category?.name || '资讯'}</span>
    </nav>

    {/* 文章头部 */}
    <header class="mb-8">
      <div class="mb-4 flex flex-wrap gap-2">
        {
          category && (
            <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
              {category.name}
            </span>
          )
        }
        {
          articleTags.slice(0, 3).map((tag) => (
            <a
              href={getLocalizedPath('/tag/' + tag.slug, lang)}
              class="rounded-full border border-border px-3 py-1 text-xs text-text-secondary hover:border-accent hover:text-accent"
            >
              {tag.name}
            </a>
          ))
        }
      </div>

      <h1 class="text-3xl font-bold text-text-primary md:text-4xl">
        {article.title}
      </h1>

      <p class="mt-4 text-lg text-text-secondary">
        {article.excerpt || article.description}
      </p>

      {/* 作者和元信息 */}
      <div class="mt-6 flex flex-wrap items-center gap-4 border-b border-border pb-6">
        <div class="flex items-center gap-3">
          <div
            class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/10 text-accent"
          >
            {(article.author || 'A')[0]}
          </div>
          <div>
            <p class="text-sm font-medium text-text-primary">{article.author || '佚名'}</p>
            <p class="text-xs text-text-tertiary">
              {
                article.publishedAt?.toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })
              }
            </p>
          </div>
        </div>
        <div class="flex items-center gap-4 text-sm text-text-tertiary">
          <span>{article.readingTime || 5} 分钟阅读</span>
          <span>{(article.viewCount || 0).toLocaleString()} 阅读</span>
          <span>{article.likeCount || 0} 点赞</span>
          <span>{article.commentCount || 0} 评论</span>
        </div>
      </div>
    </header>

    {/* 封面图 */}
    {
      article.coverImage && (
        <div class="mb-8 overflow-hidden rounded-xl">
          <img src={article.coverImage} alt={article.title} class="w-full object-cover" />
        </div>
      )
    }

    {/* 文章内容 */}
    <div class="prose mb-12" set:html={article.content} />

    {/* 操作栏 */}
    <div
      class="mb-12 flex items-center justify-between rounded-xl border border-border bg-card p-4"
    >
      <div class="flex items-center gap-4">
        <button
          class="flex items-center gap-2 rounded-lg px-4 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-accent"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
            ></path>
          </svg>
          {t('news.likes')}
        </button>
        <button
          class="flex items-center gap-2 rounded-lg px-4 py-2 text-sm text-text-secondary transition-colors hover:bg-background-hover hover:text-accent"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path>
          </svg>
          {t('news.bookmark')}
        </button>
      </div>
      <div class="flex items-center gap-2">
        <button
          class="flex h-9 w-9 items-center justify-center rounded-lg text-text-secondary transition-colors hover:bg-background-hover hover:text-accent"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
            ></path>
          </svg>
        </button>
      </div>
    </div>

    {/* 来源 */}
    {
      article.sourceUrl && (
        <div class="mb-12 rounded-xl border border-border bg-card p-4">
          <p class="text-sm text-text-secondary">
            原文来源：
            <a
              href={article.sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:underline"
            >
              {article.sourceName || '原文链接'}
            </a>
          </p>
        </div>
      )
    }

    {/* 相关文章 */}
    {
      relatedArticles.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-6 text-xl font-semibold text-text-primary">{t('news.related')}</h2>
          <div class="grid gap-4 sm:grid-cols-3">
            {relatedArticles.map((related) => (
              <a
                href={getLocalizedPath('/news/' + related.slug, lang)}
                class="group rounded-xl border border-border bg-card p-4 transition-all hover:border-border-strong hover:bg-card-hover"
              >
                <h3 class="text-sm font-medium text-text-primary transition-colors group-hover:text-accent">
                  {related.title}
                </h3>
                <p class="mt-2 text-xs text-text-tertiary">
                  {related.publishedAt?.toLocaleDateString('zh-CN', {
                    month: 'short',
                    day: 'numeric',
                  })}
                </p>
              </a>
            ))}
          </div>
        </div>
      )
    }

    {/* 评论占位 */}
    <div class="rounded-xl border border-border bg-card p-6">
      <h2 class="mb-4 text-xl font-semibold text-text-primary">{t('news.comments')}</h2>
      <p class="text-sm text-text-secondary">评论功能即将上线，敬请期待。</p>
    </div>
  </article>
</BaseLayout>
