---
// src/pages/news/index.astro
// 功能：新闻列表页面（中文） — 分类筛选标签、文章网格、分页
import BaseLayout from '@/layouts/BaseLayout.astro';
import NewsCard from '@/components/news/NewsCard.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { db, schema } from '@/lib/db';
import { eq, desc, and, sql } from 'drizzle-orm';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const page = parseInt(Astro.url.searchParams.get('page') || '1');
const limit = 12;
const offset = (page - 1) * limit;

const articles = await db
  .select()
  .from(schema.articles)
  .where(and(eq(schema.articles.status, 'published'), eq(schema.articles.lang, 'zh')))
  .orderBy(desc(schema.articles.publishedAt))
  .limit(limit)
  .offset(offset);

const [{ count: total }] = await db
  .select({ count: sql<number>`count(*)` })
  .from(schema.articles)
  .where(and(eq(schema.articles.status, 'published'), eq(schema.articles.lang, 'zh')));

const totalPages = Math.ceil(total / limit);

const categories = [
  { name: '全部', slug: 'all' },
  { name: 'AI 公司', slug: 'ai-companies' },
  { name: '学术研究', slug: 'research' },
  { name: 'AI 产品', slug: 'ai-products' },
  { name: '行业动态', slug: 'industry' },
  { name: '开源项目', slug: 'open-source' },
];
---

<BaseLayout title={t('nav.news')} description={t('home.hero.subtitle')}>
  <div class="mx-auto max-w-7xl px-4 py-8">
    {/* Page Header */}
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-text-primary">{t('nav.news')}</h1>
      <p class="mt-2 text-text-secondary">浏览所有 AI 新闻与资讯</p>
    </div>

    {/* Category Filter */}
    <div class="mb-8 flex flex-wrap gap-2">
      {
        categories.map((cat, i) => (
          <button
            class={`rounded-full px-4 py-2 text-sm font-medium transition-colors ${
              i === 0
                ? 'bg-accent text-white'
                : 'border border-border bg-background text-text-secondary hover:border-accent hover:text-accent'
            }`}
            data-category={cat.slug}
          >
            {cat.name}
          </button>
        ))
      }
    </div>

    {/* Articles Grid */}
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {articles.map((article) => <NewsCard {...article} lang={lang} />)}
    </div>

    {/* Empty State */}
    {
      articles.length === 0 && (
        <div class="py-12 text-center">
          <p class="text-text-tertiary">{t('common.noData')}</p>
        </div>
      )
    }

    {/* Pagination */}
    {
      totalPages > 1 && (
        <div class="mt-12 flex justify-center">
          <div class="flex items-center gap-2">
            <a
              href={`?page=${page - 1}`}
              class={`rounded-lg border border-border bg-background px-4 py-2 text-sm transition-colors ${
                page <= 1
                  ? 'pointer-events-none text-text-tertiary opacity-50'
                  : 'text-text-secondary hover:bg-background-hover'
              }`}
            >
              {t('common.prev')}
            </a>
            <span class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white">
              {page}
            </span>
            <a
              href={`?page=${page + 1}`}
              class={`rounded-lg border border-border bg-background px-4 py-2 text-sm transition-colors ${
                page >= totalPages
                  ? 'pointer-events-none text-text-tertiary opacity-50'
                  : 'text-text-secondary hover:bg-background-hover'
              }`}
            >
              {t('common.next')}
            </a>
          </div>
        </div>
      )
    }
  </div>
</BaseLayout>
