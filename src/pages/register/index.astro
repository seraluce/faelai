---
// src/pages/register/index.astro
// 功能：注册页面（中文） — 用户名、邮箱、验证码（60秒倒计时）、密码、确认密码表单
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

if (Astro.locals.user) {
  return Astro.redirect(getLocalizedPath('/', lang));
}
---

<BaseLayout title={t('auth.register.title')}>
  <div
    class="mx-auto flex min-h-[calc(100vh-8rem)] max-w-md items-center justify-center px-4 py-12"
  >
    <div class="w-full">
      <div class="mb-8 text-center">
        <h1 class="text-2xl font-bold text-text-primary">{t('auth.register.title')}</h1>
        <p class="mt-2 text-sm text-text-secondary">创建账号以参与互动</p>
      </div>

      <form id="register-form" class="space-y-4">
        <div>
          <label for="username" class="mb-1 block text-sm font-medium text-text-secondary">
            {t('auth.register.username')}
          </label>
          <input
            type="text"
            id="username"
            name="username"
            required
            minlength="3"
            maxlength="30"
            class="w-full rounded-lg border border-border bg-background px-4 py-3 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
            placeholder="username"
          />
        </div>

        <div>
          <label for="email" class="mb-1 block text-sm font-medium text-text-secondary">
            {t('auth.login.email')}
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full rounded-lg border border-border bg-background px-4 py-3 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
            placeholder="your@email.com"
          />
        </div>

        {/* Email Verification Code */}
        <div>
          <label for="code" class="mb-1 block text-sm font-medium text-text-secondary">
            邮箱验证码
          </label>
          <div class="flex gap-2">
            <input
              type="text"
              id="code"
              name="code"
              required
              maxlength="6"
              pattern="[0-9]{6}"
              class="flex-1 rounded-lg border border-border bg-background px-4 py-3 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
              placeholder="6 位验证码"
            />
            <button
              type="button"
              id="send-code-btn"
              class="shrink-0 rounded-lg border border-border bg-background-secondary px-4 py-3 text-sm font-medium text-text-secondary transition-colors hover:bg-background-hover hover:text-text-primary"
            >
              发送验证码
            </button>
          </div>
          <p id="code-hint" class="mt-1 hidden text-xs text-accent"></p>
        </div>

        <div>
          <label for="password" class="mb-1 block text-sm font-medium text-text-secondary">
            {t('auth.login.password')}
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="8"
            class="w-full rounded-lg border border-border bg-background px-4 py-3 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
            placeholder="至少 8 个字符"
          />
        </div>

        <div>
          <label for="confirm-password" class="mb-1 block text-sm font-medium text-text-secondary">
            确认密码
          </label>
          <input
            type="password"
            id="confirm-password"
            name="confirm-password"
            required
            minlength="8"
            class="w-full rounded-lg border border-border bg-background px-4 py-3 text-text-primary placeholder-text-tertiary transition-colors focus:border-accent focus:outline-none"
            placeholder="••••••••"
          />
        </div>

        <div id="error-message" class="hidden rounded-lg bg-error/10 px-4 py-3 text-sm text-error">
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full rounded-lg bg-accent py-3 font-medium text-white transition-colors hover:bg-accent-hover disabled:opacity-50"
        >
          {t('auth.register.submit')}
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-text-secondary">
        {t('auth.login.hasAccount')}
        <a href={getLocalizedPath('/login', lang)} class="font-medium text-accent hover:underline">
          {t('auth.login.title')}
        </a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message')!;
  const sendCodeBtn = document.getElementById('send-code-btn') as HTMLButtonElement;
  const codeHint = document.getElementById('code-hint')!;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  // Send verification code
  sendCodeBtn?.addEventListener('click', async () => {
    const email = emailInput.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorDiv.textContent = '请先输入有效的邮箱地址';
      errorDiv.classList.remove('hidden');
      return;
    }

    errorDiv.classList.add('hidden');
    sendCodeBtn.disabled = true;
    sendCodeBtn.textContent = '发送中...';

    try {
      const res = await fetch('/api/auth/send-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();

      if (!res.ok) {
        errorDiv.textContent = data.error;
        errorDiv.classList.remove('hidden');
        sendCodeBtn.disabled = false;
        sendCodeBtn.textContent = '发送验证码';
        return;
      }

      // Dev mode: show code
      if (data.devCode) {
        codeHint.textContent = `开发模式验证码: ${data.devCode}`;
        codeHint.classList.remove('hidden');
      }

      // Countdown
      let seconds = 60;
      sendCodeBtn.textContent = `${seconds}s`;
      const timer = setInterval(() => {
        seconds--;
        sendCodeBtn.textContent = `${seconds}s`;
        if (seconds <= 0) {
          clearInterval(timer);
          sendCodeBtn.disabled = false;
          sendCodeBtn.textContent = '发送验证码';
        }
      }, 1000);
    } catch {
      errorDiv.textContent = '网络错误，请稍后重试';
      errorDiv.classList.remove('hidden');
      sendCodeBtn.disabled = false;
      sendCodeBtn.textContent = '发送验证码';
    }
  });

  // Submit registration
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const formData = new FormData(form);
    const username = formData.get('username') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirm-password') as string;
    const code = formData.get('code') as string;

    if (password !== confirmPassword) {
      errorDiv.textContent = '两次输入的密码不一致';
      errorDiv.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = '注册中...';

    try {
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, username, password, code }),
      });

      const data = await res.json();

      if (!res.ok) {
        errorDiv.textContent = data.error;
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = '注册';
        return;
      }

      const lang = window.location.pathname.startsWith('/en') ? 'en' : '';
      window.location.href = lang ? `/${lang}/` : '/';
    } catch {
      errorDiv.textContent = '网络错误，请稍后重试';
      errorDiv.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = '注册';
    }
  });
</script>
